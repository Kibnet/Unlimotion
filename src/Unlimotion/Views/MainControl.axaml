<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModel="clr-namespace:Unlimotion.ViewModel;assembly=Unlimotion.ViewModel"
             xmlns:unlimotion="clr-namespace:Unlimotion"
             xmlns:views="clr-namespace:Unlimotion.Views"
             xmlns:converters="clr-namespace:Unlimotion.Converters"
             xmlns:behavior="clr-namespace:Unlimotion.Behavior"
             xmlns:domain="clr-namespace:Unlimotion.Domain;assembly=Unlimotion.Domain"
             xmlns:searchControl="clr-namespace:Unlimotion.Views.SearchControl"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="viewModel:MainWindowViewModel"
             Name="mainControl"
             x:Class="Unlimotion.Views.MainControl">

    <Design.DataContext>
        <viewModel:MainWindowViewModel/>
    </Design.DataContext>
    <UserControl.Resources>
        <unlimotion:TimeSpanStringConverter x:Key="TimeSpanStringConverter"/>
        <unlimotion:EqualConverter x:Key="EqualConverter"/>
        <unlimotion:NotEqualConverter x:Key="NotEqualConverter"/>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="Grid.FilterToolbar">
            <Setter Property="ColumnSpacing" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="WrapPanel.FilterToolbarItems">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style Selector="searchControl|SearchBar.FilterToolbarSearch">
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Border.FilterOverflowPanel">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="ScrollViewer.FilterPanelScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style Selector="TextBlock.FilterPanelGroupTitle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Button.FilterPanelResetButton">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="DropDownButton.FilterToolbarFiltersButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="{DynamicResource AppSearchControlHeight}"/>
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="MinHeight" Value="{DynamicResource AppSearchControlHeight}"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="PathIcon.FilterToolbarFiltersIcon">
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <Style Selector="PathIcon.FilterPanelResetIcon">
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel">
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Spacing" Value="8"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Spacing" Value="6"/>
        </Style>
        <Style Selector="WrapPanel.TaskCommandBar">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,4"/>
        </Style>
        <Style Selector="Button.TaskCommandButton">
            <Setter Property="Margin" Value="0,0,6,4"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style Selector="Button.TaskCommandPrimaryButton">
            <Setter Property="Background" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.TaskCommandSecondaryButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.TaskCommandDangerButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B3261E"/>
            <Setter Property="BorderBrush" Value="#66B3261E"/>
        </Style>
        <Style Selector="DropDownButton.TaskCommandOverflowButton">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,6,4"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style Selector="DropDownButton.TaskActionsMenuButton">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="7,0,3,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="Background" Value="#F7FAFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="DropDownButton.TaskCreateMenuButton">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="50"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="7,0,5,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource ThemeControlLowBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact Button.TaskCommandSecondaryButton">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact DropDownButton.TaskCommandOverflowButton">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
        <Style Selector="Button.MainTabsOverflowButton">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="{DynamicResource AppTabMinHeight}"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style Selector="Button.MainTabsOverflowButton:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.MainTabsOverflowButton:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Border.CurrentTaskCard">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeControlLowBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact Border.CurrentTaskCard">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="StackPanel.CurrentTaskCardContent">
            <Setter Property="Spacing" Value="8"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact StackPanel.CurrentTaskCardContent">
            <Setter Property="Spacing" Value="6"/>
        </Style>
        <Style Selector="Grid.TaskCardHeader">
            <Setter Property="ColumnSpacing" Value="6"/>
            <Setter Property="RowSpacing" Value="6"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact Grid.TaskCardHeader">
            <Setter Property="ColumnSpacing" Value="6"/>
            <Setter Property="RowSpacing" Value="6"/>
        </Style>
        <Style Selector="CheckBox.TaskHeaderCompletionCheckBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="WrapPanel.TaskHeaderStateRow">
            <Setter Property="Orientation" Value="Horizontal"/>
        </Style>
        <Style Selector="CheckBox.TaskHeaderStateCheckBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,4"/>
        </Style>
        <Style Selector="NumericUpDown.TaskHeaderImportanceInput">
            <Setter Property="Width" Value="86"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,4"/>
        </Style>
        <Style Selector="WrapPanel.TaskHeaderMetaRow">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Opacity" Value="0.78"/>
        </Style>
        <Style Selector="TextBlock.TaskHeaderIdMeta">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="FontSize" Value="{DynamicResource AppSmallFontSize}"/>
            <Setter Property="Margin" Value="0,0,8,4"/>
            <Setter Property="MinHeight" Value="22"/>
        </Style>
        <Style Selector="WrapPanel.TaskHeaderDateMeta">
            <Setter Property="Margin" Value="0,0,8,4"/>
        </Style>
        <Style Selector="WrapPanel.TaskHeaderDateMeta Label">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="{DynamicResource AppSmallFontSize}"/>
        </Style>
        <Style Selector="TextBox.CurrentTaskTitleEditor">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact TextBox.CurrentTaskTitleEditor">
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style Selector="Border.TaskCardSection">
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="0,5,0,0"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact Border.TaskCardSection">
            <Setter Property="Padding" Value="0,5,0,0"/>
        </Style>
        <Style Selector="StackPanel.TaskCardSectionContent">
            <Setter Property="Spacing" Value="5"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact StackPanel.TaskCardSectionContent">
            <Setter Property="Spacing" Value="4"/>
        </Style>
        <Style Selector="TextBlock.TaskCardSectionTitle">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="{DynamicResource AppSmallFontSize}"/>
            <Setter Property="Opacity" Value="0.78"/>
        </Style>
        <Style Selector="TextBox.TaskDescriptionEditor">
            <Setter Property="MinHeight" Value="82"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact TextBox.TaskDescriptionEditor">
            <Setter Property="MinHeight" Value="72"/>
        </Style>
        <Style Selector="WrapPanel.TaskPlanningGroups">
            <Setter Property="Orientation" Value="Horizontal"/>
        </Style>
        <Style Selector="StackPanel.TaskPlanningGroup">
            <Setter Property="Width" Value="176"/>
            <Setter Property="Margin" Value="0,0,4,5"/>
            <Setter Property="Spacing" Value="0"/>
        </Style>
        <Style Selector="Grid.TaskPlanningFieldRow">
            <Setter Property="ColumnSpacing" Value="4"/>
        </Style>
        <Style Selector="CalendarDatePicker.TaskPlanningValueControl">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>
        <Style Selector="TextBox.TaskPlanningValueControl">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>
        <Style Selector="DropDownButton.TaskPlanningQuickAction">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="46"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="5,0,2,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="Background" Value="#F7FAFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="WrapPanel.RepeaterControls">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style Selector="WrapPanel.RepeaterPatternControls">
            <Setter Property="Orientation" Value="Horizontal"/>
        </Style>
        <Style Selector="Border.RepeaterPatternHost">
            <Setter Property="Width" Value="360"/>
        </Style>
        <Style Selector="ComboBox.RepeaterSelector">
            <Setter Property="Width" Value="148"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,5"/>
        </Style>
        <Style Selector="ComboBox.RepeaterPatternTypeSelector">
            <Setter Property="Width" Value="120"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,5"/>
        </Style>
        <Style Selector="NumericUpDown.RepeaterPeriodInput">
            <Setter Property="Width" Value="64"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,5"/>
        </Style>
        <Style Selector="CheckBox.RepeaterAfterCompleteCheckBox">
            <Setter Property="Width" Value="156"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,5"/>
        </Style>
        <Style Selector="WrapPanel.WeekdayToggles">
            <Setter Property="Orientation" Value="Horizontal"/>
        </Style>
        <Style Selector="ToggleButton.WeekdayToggle">
            <Setter Property="Width" Value="46"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Grid.RelationSectionHeader">
            <Setter Property="ColumnSpacing" Value="8"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>
        <Style Selector="Grid.RelationSectionHeader Label">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{DynamicResource AppSmallFontSize}"/>
            <Setter Property="Opacity" Value="0.76"/>
        </Style>
        <Style Selector="Button.RelationAddButton">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="Background" Value="#F7FAFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="StackPanel.RelationPickerRow">
            <Setter Property="Spacing" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="Border.RelationEditorCard">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#33000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact Border.RelationEditorCard">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBox.RelationEditorSearch">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ListBox.RelationEditorSuggestions">
            <Setter Property="MaxHeight" Value="240"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor">
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor:focus">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor:focus:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor.IsWanted">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.TaskRowRemoveButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#B3261E"/>
            <Setter Property="Opacity" Value="0.62"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>
        <Style Selector="TreeView.TaskTree">
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="{DynamicResource ExpandCurrentNested}"
                                  Tag="ExpandCurrentNested"
                                  InputGesture="Ctrl+Shift+Right"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="ExpandCurrentNestedTreeMenuItem"/>
                        <MenuItem Header="{DynamicResource CollapseCurrentNested}"
                                  Tag="CollapseCurrentNested"
                                  InputGesture="Ctrl+Shift+Left"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="CollapseCurrentNestedTreeMenuItem"/>
                        <MenuItem Header="{DynamicResource ExpandAllNodes}"
                                  Tag="ExpandAll"
                                  InputGesture="Ctrl+Alt+Right"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="ExpandAllTreeMenuItem"/>
                        <MenuItem Header="{DynamicResource CollapseAllNodes}"
                                  Tag="CollapseAll"
                                  InputGesture="Ctrl+Alt+Left"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="CollapseAllTreeMenuItem"/>
                        <Separator/>
                        <MenuItem Header="{DynamicResource CopyTaskOutline}"
                                  Tag="CopyOutline"
                                  InputGesture="Ctrl+Shift+C"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="CopyTaskOutlineTreeMenuItem"/>
                        <MenuItem Header="{DynamicResource PasteTaskOutline}"
                                  Tag="PasteOutline"
                                  InputGesture="Ctrl+Shift+V"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="PasteTaskOutlineTreeMenuItem"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="TreeView.TaskTree TreeViewItem">
            <Setter Property="IsExpanded">
                <Setter.Value>
                    <Binding Path="((viewModel:TaskWrapperViewModel)DataContext)?.IsExpanded"
                             Mode="TwoWay"
                             RelativeSource="{RelativeSource Mode=Self}"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Styles>
    <UserControl.DataTemplates>
        <DataTemplate DataType="viewModel:TaskItemViewModel">
            <Grid ColumnDefinitions="Auto, Auto, *" Background="Transparent" DragDrop.AllowDrop="True">
                <CheckBox IsChecked="{Binding IsCompleted}" VerticalAlignment="Center" IsEnabled="{Binding IsCanBeCompleted}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding RepeaterListMarker}"
                           IsVisible="{Binding IsHaveRepeater}"
                           ToolTip.Tip="{Binding RepeaterListMarkerToolTip}"
                           AutomationProperties.AutomationId="TaskRepeaterListMarker"
                           Margin="4,0,4,0"
                           VerticalAlignment="Center" />
                <unlimotion:EmojiTextBlock Grid.Column="2" EmojiText="{Binding Title}" VerticalAlignment="Center" HorizontalAlignment="Left" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" AutomationProperties.AutomationId="InlineTaskTitleTextBlock" Classes.IsWanted="{Binding Wanted}" Classes.IsCanBeCompleted="{Binding !IsCanBeCompleted}" PointerPressed="InlineTaskTitleText_OnPointerPressed"  />
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="viewModel:TaskWrapperViewModel">
            <Grid ColumnDefinitions="*,Auto" Background="Transparent">
                <ContentControl Content="{Binding TaskItem}" MinWidth="0"/>
                <Button Grid.Column="1"
                        Classes="TaskRowRemoveButton"
                        Content="×"
                        ToolTip.Tip="{DynamicResource Remove}"
                        Command="{Binding RemoveCommand}"/>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="viewModel:TaskRelationCandidateViewModel">
            <StackPanel Margin="4,2">
                <TextBlock Text="{Binding Title}" />
                <TextBlock Text="{Binding Context}" Opacity="0.7" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="viewModel:EmojiFilter">
            <Grid ColumnDefinitions="Auto, Auto" >
                <CheckBox IsChecked="{Binding ShowTasks}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="viewModel:UnlockedTimeFilter">
            <CheckBox Content="{Binding Title}" IsChecked="{Binding ShowTasks}" VerticalAlignment="Center"/>
        </DataTemplate>
        <DataTemplate DataType="viewModel:DurationFilter">
            <CheckBox Content="{Binding Title}" IsChecked="{Binding ShowTasks}" VerticalAlignment="Center"/>
        </DataTemplate>
    </UserControl.DataTemplates>

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Shift+Delete" Command="{Binding DeleteSelectedTreeItemsCommand}"/>
        <KeyBinding Gesture="Ctrl+Enter" Command="{Binding CreateSibling}"/>
        <KeyBinding Gesture="Shift+Enter" Command="{Binding CreateBlockedSibling}"/>
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding CreateInner}"/>
        <KeyBinding Gesture="Ctrl+Shift+Right" Command="{Binding ExpandCurrentNestedCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+Left" Command="{Binding CollapseCurrentNestedCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+Right" Command="{Binding ExpandAllTreeNodesCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+Left" Command="{Binding CollapseAllTreeNodesCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding CopyTaskOutlineTreeCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+V" Command="{Binding PasteTaskOutlineTreeCommand}"/>
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*">
        <!--Адрес-->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="10,5" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <unlimotion:EmojiTextBlock x:Name="BreadcrumbsTextBlock"
                                       AutomationProperties.AutomationId="BreadcrumbsTextBlock"
                                       EmojiText="{Binding BreadScrumbs}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"
                                       ToolTip.Tip="{Binding BreadScrumbs}"
                                       PointerPressed="BreadScrumbs_OnPointerPressed"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"/>
            <DropDownButton Grid.Column="1"
                            Classes="TaskCreateMenuButton"
                            Content="➕"
                            ToolTip.Tip="{DynamicResource NewTask}"
                            AutomationProperties.AutomationId="GlobalTaskCreateMenuButton">
                <DropDownButton.Flyout>
                    <MenuFlyout>
                        <MenuItem Header="{DynamicResource NewTask}"
                                  Command="{Binding Create}"
                                  AutomationProperties.AutomationId="GlobalTaskCreateTaskMenuItem"/>
                        <MenuItem Header="{DynamicResource NewSibling}"
                                  Command="{Binding CreateSibling}"
                                  AutomationProperties.AutomationId="GlobalTaskCreateSiblingMenuItem"/>
                        <MenuItem Header="{DynamicResource NewBlockedSibling}"
                                  Command="{Binding CreateBlockedSibling}"
                                  AutomationProperties.AutomationId="GlobalTaskCreateBlockedSiblingMenuItem"/>
                        <MenuItem Header="{DynamicResource NewInner}"
                                  Command="{Binding CreateInner}"
                                  AutomationProperties.AutomationId="GlobalTaskCreateInnerMenuItem"/>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>
        </Grid>

        <!--Панель навигации-->
        <SplitView x:Name="MainNavigationSplitView"
                   Grid.Row="1"
                   IsPaneOpen="{Binding DetailsAreOpen}"
                   DisplayMode="CompactInline"
                   UseLightDismissOverlayMode="False"
                   OpenPaneLength="{Binding #mainControl.Bounds.Width, Converter={converters:MinValueConverter}, ConverterParameter=600}"
                   CompactPaneLength="20"
                   PanePlacement="Right">
            <Grid x:Name="MainTabsHost"
                  Margin="10,0,0,0"
                  HorizontalAlignment="Left">
                <TabControl x:Name="MainTabs"
                            TabStripPlacement="Top"
                            ClipToBounds="True"
                            Margin="0"
                            Padding="0"
                            SelectionChanged="MainTabs_OnSelectionChanged"
                            AutomationProperties.AutomationId="MainTabs">
                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="FontSize" Value="{DynamicResource AppTabFontSize}"/>
                            <Setter Property="Padding" Value="0,0,6,0"/>
                            <Setter Property="MinHeight" Value="{DynamicResource AppTabMinHeight}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                        <Style Selector="TabControl /template/ ContentPresenter#PART_SelectedContentHost">
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </TabControl.Styles>
                    <!--All Tasks-->
                    <TabItem Header="{DynamicResource AllTasks}" IsSelected= "{Binding AllTasksMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="AllTasksTabItem">
                        <Grid RowDefinitions= "Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
                                    <DropDownButton Classes="FilterToolbarFiltersButton"
                                                    ToolTip.Tip="{DynamicResource Filters}"
                                                    AutomationProperties.Name="{DynamicResource Filters}"
                                                    Margin="0"
                                                    AutomationProperties.AutomationId="AllTasksFiltersButton">
                                        <PathIcon Classes="FilterToolbarFiltersIcon" Width="15" Height="15" Data="M3,5 L21,5 L21,7 L3,7 Z M7,11 L17,11 L17,13 L7,13 Z M10,17 L14,17 L14,19 L10,19 Z"/>
                                        <DropDownButton.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Classes="FilterOverflowPanel"
                                                        MinWidth="0"
                                                        MaxWidth="360"
                                                        AutomationProperties.AutomationId="AllTasksFilterPanel">
                                                    <ScrollViewer Classes="FilterPanelScrollViewer">
                                                        <StackPanel Spacing="10">
                                                            <StackPanel>
                                                                <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterSort}"/>
                                                                <ComboBox ItemsSource="{Binding SortDefinitions}" SelectedItem="{Binding CurrentSortDefinition}" MinWidth="220"/>
                                                            </StackPanel>
                                                            <StackPanel>
                                                                <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterTags}"/>
                                                                <WrapPanel>
                                                                    <ComboBox ItemsSource="{Binding EmojiFilters}" Margin="0,0,8,6"/>
                                                                    <ComboBox ItemsSource="{Binding EmojiExcludeFilters}" Margin="0,0,8,6" BorderBrush="Red" BorderThickness="2"/>
                                                                </WrapPanel>
                                                            </StackPanel>
                                                            <StackPanel>
                                                                <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterState}"/>
                                                                <WrapPanel>
                                                                    <CheckBox Content="{DynamicResource Completed}" IsChecked="{Binding ShowCompleted}" Margin="0,0,12,6"/>
                                                                    <CheckBox Content="{DynamicResource Archived}" IsChecked="{Binding ShowArchived}" Margin="0,0,12,6"/>
                                                                </WrapPanel>
                                                            </StackPanel>
                                                            <Button Classes="FilterPanelResetButton"
                                                                    ToolTip.Tip="{DynamicResource ResetFilters}"
                                                                    AutomationProperties.Name="{DynamicResource ResetFilters}"
                                                                    Command="{Binding ResetTaskFiltersCommand}"
                                                                    AutomationProperties.AutomationId="AllTasksResetFiltersButton">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <PathIcon Classes="FilterPanelResetIcon" Width="16" Height="16" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.82,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                                                                    <TextBlock Text="{DynamicResource ResetFilters}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Flyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                </WrapPanel>
                                <searchControl:SearchBar Grid.Column="1" Classes="FilterToolbarSearch" DataContext="{Binding Search}"/>
                            </Grid>
                            <TreeView Grid.Row= "1" AutoScrollToSelectedItem= "True"
                                      ItemsSource="{Binding CurrentAllTasksItems}"
                                      SelectedItem="{Binding CurrentAllTasksItem}"
                                      SelectionMode= "Multiple"
                                      Classes="TaskTree"
                                      PointerPressed="TaskTree_OnPointerPressed"
                                      KeyDown="TaskTree_OnKeyDown"
                                      AutomationProperties.AutomationId="AllTasksTree"
                                      x:Name="AllTasksTree">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType= "viewModel:TaskWrapperViewModel" ItemsSource= "{Binding SubTasks}">
                                        <ContentControl Content= "{Binding .}" PointerPressed= "InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased" DoubleTapped= "TaskTree_OnDoubleTapped"/>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Last Created-->
                    <TabItem Header="{DynamicResource LastCreated}" IsSelected="{Binding LastCreatedMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="LastCreatedTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
                                    <DropDownButton Classes="FilterToolbarFiltersButton"
                                                    ToolTip.Tip="{DynamicResource Filters}"
                                                    AutomationProperties.Name="{DynamicResource Filters}"
                                                    Margin="0"
                                                    AutomationProperties.AutomationId="LastCreatedFiltersButton">
                                        <PathIcon Classes="FilterToolbarFiltersIcon" Width="15" Height="15" Data="M3,5 L21,5 L21,7 L3,7 Z M7,11 L17,11 L17,13 L7,13 Z M10,17 L14,17 L14,19 L10,19 Z"/>
                                        <DropDownButton.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Classes="FilterOverflowPanel"
                                                        MinWidth="0"
                                                        MaxWidth="360"
                                                        AutomationProperties.AutomationId="LastCreatedFilterPanel">
                                                    <ScrollViewer Classes="FilterPanelScrollViewer">
                                                    <StackPanel Spacing="10">
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterTags}"/>
                                                            <WrapPanel>
                                                                <ComboBox ItemsSource="{Binding EmojiFilters}" Margin="0,0,8,6"/>
                                                                <ComboBox ItemsSource="{Binding EmojiExcludeFilters}" Margin="0,0,8,6" BorderBrush="Red" BorderThickness="2"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterDate}"/>
                                                            <WrapPanel>
                                                                <CheckBox Content="{DynamicResource CustomPeriod}" IsChecked="{Binding LastCreatedDateFilter.IsCustom}" Margin="0,0,12,6" VerticalAlignment="Center"/>
                                                                <ComboBox IsVisible="{Binding !LastCreatedDateFilter.IsCustom}" ItemsSource="{Binding DateFilterDefinitions}" SelectedItem="{Binding LastCreatedDateFilter.CurrentOption}" VerticalAlignment="Center" Margin="0,0,8,6" />
                                                            </WrapPanel>
                                                            <WrapPanel IsVisible="{Binding LastCreatedDateFilter.IsCustom}">
                                                                <Label Content="{DynamicResource From}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding LastCreatedDateFilter.From}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding LastCreatedDateFilter.From, Converter={converters:DayOrTodayValueConverter}}"/>
                                                                <Label Content="{DynamicResource To}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding LastCreatedDateFilter.To}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding LastCreatedDateFilter.To, Converter={converters:DayOrTodayValueConverter}}"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterState}"/>
                                                            <WrapPanel>
                                                                <CheckBox Content="{DynamicResource Completed}" IsChecked="{Binding ShowCompleted}" Margin="0,0,12,6"/>
                                                                <CheckBox Content="{DynamicResource Archived}" IsChecked="{Binding ShowArchived}" Margin="0,0,12,6"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <Button Classes="FilterPanelResetButton"
                                                                ToolTip.Tip="{DynamicResource ResetFilters}"
                                                                AutomationProperties.Name="{DynamicResource ResetFilters}"
                                                                Command="{Binding ResetTaskFiltersCommand}"
                                                                AutomationProperties.AutomationId="LastCreatedResetFiltersButton">
                                                            <StackPanel Orientation="Horizontal">
                                                                <PathIcon Classes="FilterPanelResetIcon" Width="16" Height="16" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.82,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                                                                <TextBlock Text="{DynamicResource ResetFilters}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Flyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                </WrapPanel>
                                <searchControl:SearchBar Grid.Column="1" Classes="FilterToolbarSearch" DataContext="{Binding Search}"/>
                            </Grid>
                            <TreeView Grid.Row="1" AutoScrollToSelectedItem="True"
                                      ItemsSource="{Binding LastCreatedItems}"
                                      SelectedItem="{Binding CurrentLastCreated}"
                                      SelectionMode="Multiple"
                                      Classes="TaskTree"
                                      PointerPressed="TaskTree_OnPointerPressed"
                                      KeyDown="TaskTree_OnKeyDown"
                                      AutomationProperties.AutomationId="LastCreatedTree"
                                      x:Name="LastCreatedTree">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                        <Grid DoubleTapped="TaskTree_OnDoubleTapped" Background="Transparent">
                                            <Grid ColumnDefinitions="Auto, Auto, Auto, Auto,*" DragDrop.AllowDrop="True" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased">
                                                <CheckBox IsChecked="{Binding TaskItem.IsCompleted}" VerticalAlignment="Center" IsEnabled="{Binding TaskItem.IsCanBeCompleted}" />
                                                <Label Grid.Column="1" Content="{Binding TaskItem.CreatedDateTime, StringFormat={}{0:yyyy.MM.dd}}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <Label Grid.Column="2" Content="{Binding TaskItem.GetAllEmoji}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TaskItem.RepeaterListMarker}"
                                                           IsVisible="{Binding TaskItem.IsHaveRepeater}"
                                                           ToolTip.Tip="{Binding TaskItem.RepeaterListMarkerToolTip}"
                                                           AutomationProperties.AutomationId="TaskRepeaterListMarker"
                                                           Margin="4,0,4,0"
                                                           VerticalAlignment="Center" />
                                                <Grid Grid.Column="4" VerticalAlignment="Center">
                                                    <unlimotion:EmojiTextBlock EmojiText="{Binding TaskItem.Title}" VerticalAlignment="Center" HorizontalAlignment="Left" AutomationProperties.AutomationId="InlineTaskTitleTextBlock" Classes.IsWanted="{Binding TaskItem.Wanted}" PointerPressed="InlineTaskTitleText_OnPointerPressed"/>
                                                </Grid>
                                            </Grid>
                                            <Button Classes="TaskRowRemoveButton"
                                                    Content="×"
                                                    ToolTip.Tip="{DynamicResource Remove}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding RemoveCommand}"/>
                                        </Grid>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Last Updated-->
                    <TabItem Header="{DynamicResource LastUpdated}" IsSelected="{Binding LastUpdatedMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="LastUpdatedTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
                                    <DropDownButton Classes="FilterToolbarFiltersButton"
                                                    ToolTip.Tip="{DynamicResource Filters}"
                                                    AutomationProperties.Name="{DynamicResource Filters}"
                                                    Margin="0"
                                                    AutomationProperties.AutomationId="LastUpdatedFiltersButton">
                                        <PathIcon Classes="FilterToolbarFiltersIcon" Width="15" Height="15" Data="M3,5 L21,5 L21,7 L3,7 Z M7,11 L17,11 L17,13 L7,13 Z M10,17 L14,17 L14,19 L10,19 Z"/>
                                        <DropDownButton.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Classes="FilterOverflowPanel"
                                                        MinWidth="0"
                                                        MaxWidth="360"
                                                        AutomationProperties.AutomationId="LastUpdatedFilterPanel">
                                                    <ScrollViewer Classes="FilterPanelScrollViewer">
                                                    <StackPanel Spacing="10">
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterTags}"/>
                                                            <WrapPanel>
                                                                <ComboBox ItemsSource="{Binding EmojiFilters}" Margin="0,0,8,6"/>
                                                                <ComboBox ItemsSource="{Binding EmojiExcludeFilters}" Margin="0,0,8,6" BorderBrush="Red" BorderThickness="2"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterDate}"/>
                                                            <WrapPanel>
                                                                <CheckBox Content="{DynamicResource CustomPeriod}" IsChecked="{Binding LastUpdatedDateFilter.IsCustom}" Margin="0,0,12,6" VerticalAlignment="Center"/>
                                                                <ComboBox IsVisible="{Binding !LastUpdatedDateFilter.IsCustom}" ItemsSource="{Binding DateFilterDefinitions}" SelectedItem="{Binding LastUpdatedDateFilter.CurrentOption}" VerticalAlignment="Center" Margin="0,0,8,6" />
                                                            </WrapPanel>
                                                            <WrapPanel IsVisible="{Binding LastUpdatedDateFilter.IsCustom}">
                                                                <Label Content="{DynamicResource From}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding LastUpdatedDateFilter.From}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding LastUpdatedDateFilter.From, Converter={converters:DayOrTodayValueConverter}}"/>
                                                                <Label Content="{DynamicResource To}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding LastUpdatedDateFilter.To}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding LastUpdatedDateFilter.To, Converter={converters:DayOrTodayValueConverter}}"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterState}"/>
                                                            <WrapPanel>
                                                                <CheckBox Content="{DynamicResource Completed}" IsChecked="{Binding ShowCompleted}" Margin="0,0,12,6"/>
                                                                <CheckBox Content="{DynamicResource Archived}" IsChecked="{Binding ShowArchived}" Margin="0,0,12,6"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <Button Classes="FilterPanelResetButton"
                                                                ToolTip.Tip="{DynamicResource ResetFilters}"
                                                                AutomationProperties.Name="{DynamicResource ResetFilters}"
                                                                Command="{Binding ResetTaskFiltersCommand}"
                                                                AutomationProperties.AutomationId="LastUpdatedResetFiltersButton">
                                                            <StackPanel Orientation="Horizontal">
                                                                <PathIcon Classes="FilterPanelResetIcon" Width="16" Height="16" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.82,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                                                                <TextBlock Text="{DynamicResource ResetFilters}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Flyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                </WrapPanel>
                                <searchControl:SearchBar Grid.Column="1" Classes="FilterToolbarSearch" DataContext="{Binding Search}"/>
                            </Grid>
                            <TreeView Grid.Row="1" AutoScrollToSelectedItem="True"
                                      ItemsSource="{Binding LastUpdatedItems}"
                                      SelectedItem="{Binding CurrentLastUpdated}"
                                      SelectionMode="Multiple"
                                      Classes="TaskTree"
                                      PointerPressed="TaskTree_OnPointerPressed"
                                      KeyDown="TaskTree_OnKeyDown"
                                      AutomationProperties.AutomationId="LastUpdatedTree"
                                      x:Name="LastUpdatedTree">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                        <Grid DoubleTapped="TaskTree_OnDoubleTapped" Background="Transparent">
                                            <Grid ColumnDefinitions="Auto, Auto, Auto, Auto,*" DragDrop.AllowDrop="True" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased">
                                                <CheckBox IsChecked="{Binding TaskItem.IsCompleted}" VerticalAlignment="Center" IsEnabled="{Binding TaskItem.IsCanBeCompleted}" />
                                                <Label Grid.Column="1" Content="{Binding TaskItem.UpdatedDateTime, StringFormat={}{0:yyyy.MM.dd}}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <Label Grid.Column="2" Content="{Binding TaskItem.GetAllEmoji}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TaskItem.RepeaterListMarker}"
                                                           IsVisible="{Binding TaskItem.IsHaveRepeater}"
                                                           ToolTip.Tip="{Binding TaskItem.RepeaterListMarkerToolTip}"
                                                           AutomationProperties.AutomationId="TaskRepeaterListMarker"
                                                           Margin="4,0,4,0"
                                                           VerticalAlignment="Center" />
                                                <Grid Grid.Column="4" VerticalAlignment="Center">
                                                    <unlimotion:EmojiTextBlock EmojiText="{Binding TaskItem.Title}" VerticalAlignment="Center" HorizontalAlignment="Left" AutomationProperties.AutomationId="InlineTaskTitleTextBlock" Classes.IsWanted="{Binding TaskItem.Wanted}" PointerPressed="InlineTaskTitleText_OnPointerPressed"/>
                                                </Grid>
                                            </Grid>
                                            <Button Classes="TaskRowRemoveButton"
                                                    Content="×"
                                                    ToolTip.Tip="{DynamicResource Remove}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding RemoveCommand}"/>
                                        </Grid>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Unlocked-->
                    <TabItem Header="{DynamicResource Unlocked}" IsSelected="{Binding UnlockedMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="UnlockedTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
                                    <DropDownButton Classes="FilterToolbarFiltersButton"
                                                    ToolTip.Tip="{DynamicResource Filters}"
                                                    AutomationProperties.Name="{DynamicResource Filters}"
                                                    Margin="0"
                                                    AutomationProperties.AutomationId="UnlockedFiltersButton">
                                        <PathIcon Classes="FilterToolbarFiltersIcon" Width="15" Height="15" Data="M3,5 L21,5 L21,7 L3,7 Z M7,11 L17,11 L17,13 L7,13 Z M10,17 L14,17 L14,19 L10,19 Z"/>
                                        <DropDownButton.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Classes="FilterOverflowPanel"
                                                        MinWidth="0"
                                                        MaxWidth="360"
                                                        AutomationProperties.AutomationId="UnlockedFilterPanel">
                                                    <ScrollViewer Classes="FilterPanelScrollViewer">
                                                    <StackPanel Spacing="10">
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterSort}"/>
                                                            <ComboBox ItemsSource="{Binding SortDefinitions}" SelectedItem="{Binding CurrentSortDefinitionForUnlocked}" MinWidth="220"/>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterTags}"/>
                                                            <WrapPanel>
                                                                <ComboBox ItemsSource="{Binding EmojiFilters}" Margin="0,0,8,6"/>
                                                                <ComboBox ItemsSource="{Binding EmojiExcludeFilters}" Margin="0,0,8,6" BorderBrush="Red" BorderThickness="2"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterState}"/>
                                                            <WrapPanel>
                                                                <CheckBox Content="{DynamicResource OnlyWanted}" IsChecked="{Binding ShowWanted}" IsThreeState="True" Margin="0,0,12,6"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterTiming}"/>
                                                            <WrapPanel>
                                                                <ComboBox ItemsSource="{Binding UnlockedTimeFilters}" Margin="0,0,8,6" />
                                                                <ComboBox ItemsSource="{Binding DurationFilters}" Margin="0,0,8,6" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <Button Classes="FilterPanelResetButton"
                                                                ToolTip.Tip="{DynamicResource ResetFilters}"
                                                                AutomationProperties.Name="{DynamicResource ResetFilters}"
                                                                Command="{Binding ResetTaskFiltersCommand}"
                                                                AutomationProperties.AutomationId="UnlockedResetFiltersButton">
                                                            <StackPanel Orientation="Horizontal">
                                                                <PathIcon Classes="FilterPanelResetIcon" Width="16" Height="16" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.82,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                                                                <TextBlock Text="{DynamicResource ResetFilters}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Flyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                </WrapPanel>
                                <searchControl:SearchBar Grid.Column="1" Classes="FilterToolbarSearch" DataContext="{Binding Search}"/>
                            </Grid>
                            <TreeView Grid.Row="1" AutoScrollToSelectedItem="True"
                                      ItemsSource="{Binding UnlockedItems}"
                                      SelectedItem="{Binding CurrentUnlockedItem}"
                                      SelectionMode="Multiple"
                                      Classes="TaskTree"
                                      PointerPressed="TaskTree_OnPointerPressed"
                                      KeyDown="TaskTree_OnKeyDown"
                                      AutomationProperties.AutomationId="UnlockedTree"
                                      x:Name="UnlockedTree">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                        <Grid DoubleTapped="TaskTree_OnDoubleTapped" Background="Transparent">
                                            <Grid ColumnDefinitions="Auto, Auto, Auto,*" DragDrop.AllowDrop="True" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased">
                                                <CheckBox IsChecked="{Binding TaskItem.IsCompleted}" VerticalAlignment="Center" IsEnabled="{Binding TaskItem.IsCanBeCompleted}" />
                                                <Label Grid.Column="1" Content="{Binding TaskItem.GetAllEmoji}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding TaskItem.RepeaterListMarker}"
                                                           IsVisible="{Binding TaskItem.IsHaveRepeater}"
                                                           ToolTip.Tip="{Binding TaskItem.RepeaterListMarkerToolTip}"
                                                           AutomationProperties.AutomationId="TaskRepeaterListMarker"
                                                           Margin="4,0,4,0"
                                                           VerticalAlignment="Center" />
                                                <Grid Grid.Column="3" VerticalAlignment="Center">
                                                    <unlimotion:EmojiTextBlock EmojiText="{Binding TaskItem.Title}" VerticalAlignment="Center" HorizontalAlignment="Left" AutomationProperties.AutomationId="InlineTaskTitleTextBlock" Classes.IsWanted="{Binding TaskItem.Wanted}" PointerPressed="InlineTaskTitleText_OnPointerPressed"/>
                                                </Grid>
                                            </Grid>
                                            <Button Classes="TaskRowRemoveButton"
                                                    Content="×"
                                                    ToolTip.Tip="{DynamicResource Remove}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding RemoveCommand}"/>
                                        </Grid>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Completed-->
                    <TabItem Header="{DynamicResource Completed}" IsSelected="{Binding CompletedMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="CompletedTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
                                    <DropDownButton Classes="FilterToolbarFiltersButton"
                                                    ToolTip.Tip="{DynamicResource Filters}"
                                                    AutomationProperties.Name="{DynamicResource Filters}"
                                                    Margin="0"
                                                    AutomationProperties.AutomationId="CompletedFiltersButton">
                                        <PathIcon Classes="FilterToolbarFiltersIcon" Width="15" Height="15" Data="M3,5 L21,5 L21,7 L3,7 Z M7,11 L17,11 L17,13 L7,13 Z M10,17 L14,17 L14,19 L10,19 Z"/>
                                        <DropDownButton.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Classes="FilterOverflowPanel"
                                                        MinWidth="0"
                                                        MaxWidth="360"
                                                        AutomationProperties.AutomationId="CompletedFilterPanel">
                                                    <ScrollViewer Classes="FilterPanelScrollViewer">
                                                    <StackPanel Spacing="10">
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterTags}"/>
                                                            <WrapPanel>
                                                                <ComboBox ItemsSource="{Binding EmojiFilters}" Margin="0,0,8,6"/>
                                                                <ComboBox ItemsSource="{Binding EmojiExcludeFilters}" Margin="0,0,8,6" BorderBrush="Red" BorderThickness="2"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterDate}"/>
                                                            <WrapPanel>
                                                                <CheckBox Content="{DynamicResource CustomPeriod}" IsChecked="{Binding CompletedDateFilter.IsCustom}" Margin="0,0,12,6" VerticalAlignment="Center"/>
                                                                <ComboBox IsVisible="{Binding !CompletedDateFilter.IsCustom}" ItemsSource="{Binding DateFilterDefinitions}" SelectedItem="{Binding CompletedDateFilter.CurrentOption}" VerticalAlignment="Center" Margin="0,0,8,6" />
                                                            </WrapPanel>
                                                            <WrapPanel IsVisible="{Binding CompletedDateFilter.IsCustom}">
                                                                <Label Content="{DynamicResource From}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding CompletedDateFilter.From}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding CompletedDateFilter.From, Converter={converters:DayOrTodayValueConverter}}"/>
                                                                <Label Content="{DynamicResource To}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding CompletedDateFilter.To}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding CompletedDateFilter.To, Converter={converters:DayOrTodayValueConverter}}"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <Button Classes="FilterPanelResetButton"
                                                                ToolTip.Tip="{DynamicResource ResetFilters}"
                                                                AutomationProperties.Name="{DynamicResource ResetFilters}"
                                                                Command="{Binding ResetTaskFiltersCommand}"
                                                                AutomationProperties.AutomationId="CompletedResetFiltersButton">
                                                            <StackPanel Orientation="Horizontal">
                                                                <PathIcon Classes="FilterPanelResetIcon" Width="16" Height="16" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.82,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                                                                <TextBlock Text="{DynamicResource ResetFilters}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Flyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                </WrapPanel>
                                <searchControl:SearchBar Grid.Column="1" Classes="FilterToolbarSearch" DataContext="{Binding Search}"/>
                            </Grid>
                            <TreeView Grid.Row="1" AutoScrollToSelectedItem="True"
                                      ItemsSource="{Binding CompletedItems}"
                                      SelectedItem="{Binding CurrentCompletedItem}"
                                      SelectionMode="Multiple"
                                      Classes="TaskTree"
                                      PointerPressed="TaskTree_OnPointerPressed"
                                      KeyDown="TaskTree_OnKeyDown"
                                      AutomationProperties.AutomationId="CompletedTree"
                                      x:Name="CompletedTree">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                        <Grid DoubleTapped="TaskTree_OnDoubleTapped" Background="Transparent">
                                            <Grid ColumnDefinitions="Auto, Auto, Auto, Auto,*" DragDrop.AllowDrop="True" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased">
                                                <CheckBox IsChecked="{Binding TaskItem.IsCompleted}" VerticalAlignment="Center" IsEnabled="{Binding TaskItem.IsCanBeCompleted}" />
                                                <Label Grid.Column="1" Content="{Binding TaskItem.CompletedDateTime, StringFormat={}{0:yyyy.MM.dd}}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <Label Grid.Column="1" Content="{Binding TaskItem.ArchiveDateTime, StringFormat={}{0:yyyy.MM.dd}}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <Label Grid.Column="2" Content="{Binding TaskItem.GetAllEmoji}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TaskItem.RepeaterListMarker}"
                                                           IsVisible="{Binding TaskItem.IsHaveRepeater}"
                                                           ToolTip.Tip="{Binding TaskItem.RepeaterListMarkerToolTip}"
                                                           AutomationProperties.AutomationId="TaskRepeaterListMarker"
                                                           Margin="4,0,4,0"
                                                           VerticalAlignment="Center" />
                                                <Grid Grid.Column="4" VerticalAlignment="Center">
                                                    <unlimotion:EmojiTextBlock EmojiText="{Binding TaskItem.Title}" VerticalAlignment="Center" HorizontalAlignment="Left" AutomationProperties.AutomationId="InlineTaskTitleTextBlock" Classes.IsWanted="{Binding TaskItem.Wanted}" PointerPressed="InlineTaskTitleText_OnPointerPressed"/>
                                                </Grid>
                                            </Grid>
                                            <Button Classes="TaskRowRemoveButton"
                                                    Content="×"
                                                    ToolTip.Tip="{DynamicResource Remove}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding RemoveCommand}"/>
                                        </Grid>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Archived-->
                    <TabItem Header="{DynamicResource Archived}" IsSelected="{Binding ArchivedMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="ArchivedTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
                                    <DropDownButton Classes="FilterToolbarFiltersButton"
                                                    ToolTip.Tip="{DynamicResource Filters}"
                                                    AutomationProperties.Name="{DynamicResource Filters}"
                                                    Margin="0"
                                                    AutomationProperties.AutomationId="ArchivedFiltersButton">
                                        <PathIcon Classes="FilterToolbarFiltersIcon" Width="15" Height="15" Data="M3,5 L21,5 L21,7 L3,7 Z M7,11 L17,11 L17,13 L7,13 Z M10,17 L14,17 L14,19 L10,19 Z"/>
                                        <DropDownButton.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Classes="FilterOverflowPanel"
                                                        MinWidth="0"
                                                        MaxWidth="360"
                                                        AutomationProperties.AutomationId="ArchivedFilterPanel">
                                                    <ScrollViewer Classes="FilterPanelScrollViewer">
                                                    <StackPanel Spacing="10">
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterTags}"/>
                                                            <WrapPanel>
                                                                <ComboBox ItemsSource="{Binding EmojiFilters}" Margin="0,0,8,6"/>
                                                                <ComboBox ItemsSource="{Binding EmojiExcludeFilters}" Margin="0,0,8,6" BorderBrush="Red" BorderThickness="2"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterDate}"/>
                                                            <WrapPanel>
                                                                <CheckBox Content="{DynamicResource CustomPeriod}" IsChecked="{Binding ArchivedDateFilter.IsCustom}" Margin="0,0,12,6" VerticalAlignment="Center" />
                                                                <ComboBox IsVisible="{Binding !ArchivedDateFilter.IsCustom}" ItemsSource="{Binding DateFilterDefinitions}" SelectedItem="{Binding ArchivedDateFilter.CurrentOption}" VerticalAlignment="Center" Margin="0,0,8,6" />
                                                            </WrapPanel>
                                                            <WrapPanel IsVisible="{Binding ArchivedDateFilter.IsCustom}">
                                                                <Label Content="{DynamicResource From}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding ArchivedDateFilter.From}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding ArchivedDateFilter.From, Converter={converters:DayOrTodayValueConverter}}"/>
                                                                <Label Content="{DynamicResource To}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding ArchivedDateFilter.To}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding ArchivedDateFilter.To, Converter={converters:DayOrTodayValueConverter}}"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <Button Classes="FilterPanelResetButton"
                                                                ToolTip.Tip="{DynamicResource ResetFilters}"
                                                                AutomationProperties.Name="{DynamicResource ResetFilters}"
                                                                Command="{Binding ResetTaskFiltersCommand}"
                                                                AutomationProperties.AutomationId="ArchivedResetFiltersButton">
                                                            <StackPanel Orientation="Horizontal">
                                                                <PathIcon Classes="FilterPanelResetIcon" Width="16" Height="16" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.82,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                                                                <TextBlock Text="{DynamicResource ResetFilters}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Flyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                </WrapPanel>
                                <searchControl:SearchBar Grid.Column="1" Classes="FilterToolbarSearch" DataContext="{Binding Search}"/>
                            </Grid>
                            <TreeView Grid.Row="1" AutoScrollToSelectedItem="True"
                                      ItemsSource="{Binding ArchivedItems}"
                                      SelectedItem="{Binding CurrentArchivedItem}"
                                      SelectionMode="Multiple"
                                      Classes="TaskTree"
                                      PointerPressed="TaskTree_OnPointerPressed"
                                      KeyDown="TaskTree_OnKeyDown"
                                      AutomationProperties.AutomationId="ArchivedTree"
                                      x:Name="ArchivedTree">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                        <Grid DoubleTapped="TaskTree_OnDoubleTapped" Background="Transparent">
                                            <Grid ColumnDefinitions="Auto, Auto, Auto, Auto,*" DragDrop.AllowDrop="True" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased">
                                                <CheckBox IsChecked="{Binding TaskItem.IsCompleted}" VerticalAlignment="Center" IsEnabled="{Binding TaskItem.IsCanBeCompleted}" />
                                                <Label Grid.Column="1" Content="{Binding TaskItem.CompletedDateTime, StringFormat={}{0:yyyy.MM.dd}}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <Label Grid.Column="1" Content="{Binding TaskItem.ArchiveDateTime, StringFormat={}{0:yyyy.MM.dd}}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <Label Grid.Column="2" Content="{Binding TaskItem.GetAllEmoji}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TaskItem.RepeaterListMarker}"
                                                           IsVisible="{Binding TaskItem.IsHaveRepeater}"
                                                           ToolTip.Tip="{Binding TaskItem.RepeaterListMarkerToolTip}"
                                                           AutomationProperties.AutomationId="TaskRepeaterListMarker"
                                                           Margin="4,0,4,0"
                                                           VerticalAlignment="Center" />
                                                <Grid Grid.Column="4" VerticalAlignment="Center">
                                                    <unlimotion:EmojiTextBlock EmojiText="{Binding TaskItem.Title}" VerticalAlignment="Center" HorizontalAlignment="Left" AutomationProperties.AutomationId="InlineTaskTitleTextBlock" Classes.IsWanted="{Binding TaskItem.Wanted}" PointerPressed="InlineTaskTitleText_OnPointerPressed"/>
                                                </Grid>
                                            </Grid>
                                            <Button Classes="TaskRowRemoveButton"
                                                    Content="×"
                                                    ToolTip.Tip="{DynamicResource Remove}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding RemoveCommand}"/>
                                        </Grid>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Last Opened-->
                    <TabItem Header="{DynamicResource LastOpened}" IsSelected="{Binding LastOpenedMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="LastOpenedTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
                                    <DropDownButton Classes="FilterToolbarFiltersButton"
                                                    ToolTip.Tip="{DynamicResource Filters}"
                                                    AutomationProperties.Name="{DynamicResource Filters}"
                                                    Margin="0"
                                                    AutomationProperties.AutomationId="LastOpenedFiltersButton">
                                        <PathIcon Classes="FilterToolbarFiltersIcon" Width="15" Height="15" Data="M3,5 L21,5 L21,7 L3,7 Z M7,11 L17,11 L17,13 L7,13 Z M10,17 L14,17 L14,19 L10,19 Z"/>
                                        <DropDownButton.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Classes="FilterOverflowPanel"
                                                        MinWidth="0"
                                                        MaxWidth="360"
                                                        AutomationProperties.AutomationId="LastOpenedFilterPanel">
                                                    <ScrollViewer Classes="FilterPanelScrollViewer">
                                                    <StackPanel Spacing="10">
                                                        <Button Classes="FilterPanelResetButton"
                                                                ToolTip.Tip="{DynamicResource ResetFilters}"
                                                                AutomationProperties.Name="{DynamicResource ResetFilters}"
                                                                Command="{Binding ResetTaskFiltersCommand}"
                                                                AutomationProperties.AutomationId="LastOpenedResetFiltersButton">
                                                            <StackPanel Orientation="Horizontal">
                                                                <PathIcon Classes="FilterPanelResetIcon" Width="16" Height="16" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.82,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                                                                <TextBlock Text="{DynamicResource ResetFilters}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Flyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                </WrapPanel>
                                <searchControl:SearchBar Grid.Column="1" Classes="FilterToolbarSearch" DataContext="{Binding Search}"/>
                            </Grid>
                            <TreeView Grid.Row="1" AutoScrollToSelectedItem="True"
                                      ItemsSource="{Binding LastOpenedItems}"
                                      SelectedItem="{Binding CurrentLastOpenedItem}"
                                      SelectionMode="Multiple"
                                      Classes="TaskTree"
                                      PointerPressed="TaskTree_OnPointerPressed"
                                      KeyDown="TaskTree_OnKeyDown"
                                      AutomationProperties.AutomationId="LastOpenedTree"
                                      x:Name="LastOpenedTree">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                        <Grid DoubleTapped="TaskTree_OnDoubleTapped" Background="Transparent">
                                            <Grid ColumnDefinitions="Auto, Auto, Auto, Auto,*" DragDrop.AllowDrop="True" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased">
                                                <CheckBox IsChecked="{Binding TaskItem.IsCompleted}" VerticalAlignment="Center" IsEnabled="{Binding TaskItem.IsCanBeCompleted}" />
                                                <Label Grid.Column="1" Content="{Binding SpecialDateTime, StringFormat={}{0:yyyy.MM.dd HH:mm:ss}}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <Label Grid.Column="2" Content="{Binding TaskItem.GetAllEmoji}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TaskItem.RepeaterListMarker}"
                                                           IsVisible="{Binding TaskItem.IsHaveRepeater}"
                                                           ToolTip.Tip="{Binding TaskItem.RepeaterListMarkerToolTip}"
                                                           AutomationProperties.AutomationId="TaskRepeaterListMarker"
                                                           Margin="4,0,4,0"
                                                           VerticalAlignment="Center" />
                                                <Grid Grid.Column="4" VerticalAlignment="Center">
                                                    <unlimotion:EmojiTextBlock EmojiText="{Binding TaskItem.Title}" VerticalAlignment="Center" HorizontalAlignment="Left" AutomationProperties.AutomationId="InlineTaskTitleTextBlock" Classes.IsWanted="{Binding TaskItem.Wanted}" Classes.IsCanBeCompleted="{Binding !TaskItem.IsCanBeCompleted}" PointerPressed="InlineTaskTitleText_OnPointerPressed"/>
                                                </Grid>
                                            </Grid>
                                            <Button Classes="TaskRowRemoveButton"
                                                    Content="×"
                                                    ToolTip.Tip="{DynamicResource Remove}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding RemoveCommand}"/>
                                        </Grid>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Roadmap-->
                    <TabItem Header="{DynamicResource Roadmap}" IsSelected="{Binding GraphMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="RoadmapTabItem">
                        <views:GraphControl DataContext="{Binding Graph}"/>
                    </TabItem>
                    <!--Settings-->
                    <TabItem Header="{DynamicResource Settings}" IsSelected="{Binding SettingsMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="SettingsTabItem">
                        <views:SettingsControl DataContext="{Binding Settings}"/>
                    </TabItem>
                </TabControl>
                <Button x:Name="MainTabsOverflowButton"
                        Classes="MainTabsOverflowButton"
                        ZIndex="1"
                        HorizontalAlignment="Left"
                        IsVisible="False"
                        AutomationProperties.AutomationId="MainTabsOverflowButton">
                    <Grid Width="18"
                          Height="14"
                          RowDefinitions="2,5,2,5,2"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          AutomationProperties.AutomationId="MainTabsOverflowIcon">
                        <Border Grid.Row="0"
                                Classes="MainTabsOverflowIconLine"
                                Width="18"
                                Height="2"
                                CornerRadius="1"
                                Background="{StaticResource AccentButtonBackground}"
                                AutomationProperties.AutomationId="MainTabsOverflowIconLine1"/>
                        <Border Grid.Row="2"
                                Classes="MainTabsOverflowIconLine"
                                Width="18"
                                Height="2"
                                CornerRadius="1"
                                Background="{StaticResource AccentButtonBackground}"
                                AutomationProperties.AutomationId="MainTabsOverflowIconLine2"/>
                        <Border Grid.Row="4"
                                Classes="MainTabsOverflowIconLine"
                                Width="18"
                                Height="2"
                                CornerRadius="1"
                                Background="{StaticResource AccentButtonBackground}"
                                AutomationProperties.AutomationId="MainTabsOverflowIconLine3"/>
                    </Grid>
                    <Button.Flyout>
                        <MenuFlyout/>
                    </Button.Flyout>
                </Button>
            </Grid>
            <SplitView.Pane>
                <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch" ColumnDefinitions="*,Auto">
                    <ToggleButton Width="20" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="↔️" VerticalAlignment="Stretch" Grid.Column="1" IsChecked="{Binding !DetailsAreOpen}"
                                  AutomationProperties.AutomationId="DetailsPaneToggleButton"></ToggleButton>
                    <ScrollViewer x:Name="CurrentTaskDetailsScrollViewer"
                                  AutomationProperties.AutomationId="CurrentTaskDetailsScrollViewer"
                                  IsVisible="{Binding DetailsAreOpen}"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  VerticalContentAlignment="Top"
                                  behavior:KeyboardAwareScrollViewer.IsEnabled="True">
                        <StackPanel x:Name="TaskDetailsPanelRoot" Classes="TaskDetailsPanel">
                            <Border Classes="CurrentTaskCard"
                                    AutomationProperties.ControlTypeOverride="Group"
                                    AutomationProperties.IsControlElementOverride="True"
                                    AutomationProperties.AutomationId="CurrentTaskCard"
                                    IsVisible="{Binding CurrentTaskItem, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <StackPanel Classes="CurrentTaskCardContent"
                                            DataContext="{Binding CurrentTaskItem}">
                                    <Grid Classes="TaskCardHeader"
                                          ColumnDefinitions="Auto,*"
                                          RowDefinitions="Auto,Auto"
                                          AutomationProperties.ControlTypeOverride="Group"
                                          AutomationProperties.IsControlElementOverride="True"
                                          AutomationProperties.AutomationId="CurrentTaskHeader">
                                        <CheckBox IsChecked="{Binding IsCompleted}"
                                                  Classes="TaskHeaderCompletionCheckBox"
                                                  VerticalAlignment="Center"
                                                  IsEnabled="{Binding IsCanBeCompleted}"
                                                  AutomationProperties.AutomationId="CurrentTaskCompletedCheckBox"/>
                                        <TextBox Grid.Column="1"
                                                 x:Name="CurrentTaskTitleTextBox"
                                                 AutomationProperties.AutomationId="CurrentTaskTitleTextBox"
                                                 Classes="CurrentTaskTitleEditor"
                                                 TextWrapping="Wrap"
                                                 Text="{Binding Title}"
                                                 PlaceholderText="{DynamicResource TitleWatermark}"
                                                 VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center"/>

                                        <WrapPanel Grid.Row="1"
                                                   Grid.ColumnSpan="2"
                                                   Classes="TaskHeaderStateRow">
                                            <CheckBox IsChecked="{Binding WantedFromUi}"
                                                      Classes="TaskHeaderStateCheckBox"
                                                      VerticalAlignment="Center"
                                                      Content="{DynamicResource Wanted}"
                                                      AutomationProperties.AutomationId="CurrentTaskWantedCheckBox" />
                                            <NumericUpDown Value="{Binding Importance}"
                                                           Classes="TaskHeaderImportanceInput"
                                                           Minimum="0"
                                                           Maximum="100"
                                                           ToolTip.Tip="{DynamicResource Importance}"
                                                           PlaceholderText="{DynamicResource Importance}"
                                                           AutomationProperties.AutomationId="CurrentTaskImportanceInput"/>
                                            <TextBlock Classes="TaskHeaderIdMeta"
                                                       Text="{Binding Id, Mode=OneWay}"
                                                       ToolTip.Tip="{Binding Id}"
                                                       AutomationProperties.AutomationId="CurrentTaskIdTextBlock"/>
                                            <WrapPanel Classes="TaskCommandBar"
                                                       IsVisible="{Binding ., Converter={x:Static ObjectConverters.IsNotNull}}"
                                                       AutomationProperties.ControlTypeOverride="Group"
                                                       AutomationProperties.IsControlElementOverride="True"
                                                       AutomationProperties.AutomationId="CurrentTaskCommandBar">
                                                <DropDownButton Classes="TaskActionsMenuButton"
                                                                Content="⚙"
                                                                ToolTip.Tip="{DynamicResource MoreActions}"
                                                                AutomationProperties.AutomationId="CurrentTaskActionsMenuButton">
                                                    <DropDownButton.Flyout>
                                                        <MenuFlyout>
                                                            <MenuItem Header="{DynamicResource MoveToPath}"
                                                                      Command="{Binding MainWindow.MoveToPath}"
                                                                      AutomationProperties.AutomationId="CurrentTaskMoveToPathMenuItem">
                                                                <MenuItem.Icon>
                                                                    <TextBlock Text="📁"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{DynamicResource Archive}"
                                                                      Command="{Binding ArchiveCommand}"
                                                                      AutomationProperties.AutomationId="CurrentTaskArchiveMenuItem">
                                                                <MenuItem.Icon>
                                                                    <TextBlock Text="📦"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{DynamicResource Remove}"
                                                                      Command="{Binding MainWindow.Remove}"
                                                                      AutomationProperties.AutomationId="CurrentTaskRemoveMenuItem">
                                                                <MenuItem.Icon>
                                                                    <TextBlock Text="🗑️"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </MenuFlyout>
                                                    </DropDownButton.Flyout>
                                                </DropDownButton>
                                            </WrapPanel>
                                            <WrapPanel Classes="TaskHeaderDateMeta TaskHeaderMetaRow" IsVisible="{Binding CreatedDateTime, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                <Label Content="{DynamicResource CreatedPrefix}" Margin="0,0,2,0"/>
                                                <Label Content="{Binding CreatedDateTime, StringFormat={}{0:yyyy.MM.dd HH:mm}}"/>
                                            </WrapPanel>
                                            <WrapPanel Classes="TaskHeaderDateMeta TaskHeaderMetaRow" IsVisible="{Binding UpdatedDateTime, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                <Label Content="{DynamicResource UpdatedPrefix}" Margin="0,0,2,0"/>
                                                <Label Content="{Binding UpdatedDateTime, StringFormat={}{0:yyyy.MM.dd HH:mm}}"/>
                                            </WrapPanel>
                                            <WrapPanel Classes="TaskHeaderDateMeta TaskHeaderMetaRow" IsVisible="{Binding UnlockedDateTime, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                <Label Content="{DynamicResource UnlockedPrefix}" Margin="0,0,2,0"/>
                                                <Label Content="{Binding UnlockedDateTime, StringFormat={}{0:yyyy.MM.dd HH:mm}}"/>
                                            </WrapPanel>
                                            <WrapPanel Classes="TaskHeaderDateMeta TaskHeaderMetaRow" IsVisible="{Binding CompletedDateTime, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                <Label Content="{DynamicResource CompletedPrefix}" Margin="0,0,2,0"/>
                                                <Label Content="{Binding CompletedDateTime, StringFormat={}{0:yyyy.MM.dd HH:mm}}"/>
                                            </WrapPanel>
                                            <WrapPanel Classes="TaskHeaderDateMeta TaskHeaderMetaRow" IsVisible="{Binding ArchiveDateTime, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                <Label Content="{DynamicResource ArchivedPrefix}" Margin="0,0,2,0"/>
                                                <Label Content="{Binding ArchiveDateTime, StringFormat={}{0:yyyy.MM.dd HH:mm}}"/>
                                            </WrapPanel>
                                        </WrapPanel>
                                    </Grid>

                                    <Border Classes="TaskCardSection"
                                            AutomationProperties.ControlTypeOverride="Group"
                                            AutomationProperties.IsControlElementOverride="True"
                                            AutomationProperties.AutomationId="CurrentTaskDescriptionSection">
                                        <StackPanel Classes="TaskCardSectionContent">
                                            <TextBox Text="{Binding Description}"
                                                     AutomationProperties.AutomationId="CurrentTaskDescriptionTextBox"
                                                     Classes="TaskDescriptionEditor"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     AcceptsTab="True"
                                                     HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="TaskCardSection"
                                            AutomationProperties.ControlTypeOverride="Group"
                                            AutomationProperties.IsControlElementOverride="True"
                                            AutomationProperties.AutomationId="CurrentTaskPlanningSection">
                                        <StackPanel Classes="TaskCardSectionContent">
                                            <WrapPanel Classes="TaskPlanningGroups">
                                                <StackPanel Classes="TaskPlanningGroup">
                                                    <Grid Classes="TaskPlanningFieldRow" ColumnDefinitions="*,Auto">
                                                        <CalendarDatePicker SelectedDate="{Binding PlannedBeginDateTime}"
                                                                            Classes="TaskPlanningValueControl"
                                                                            AutomationProperties.AutomationId="CurrentTaskPlannedBeginPicker"
                                                                            IsTodayHighlighted="True"
                                                                            PlaceholderText="{DynamicResource PlannedBegin}"
                                                                            UseFloatingPlaceholder="True"
                                                                            HorizontalAlignment="Stretch"
                                                                            DisplayDate="{Binding PlannedBeginDateTime, Mode=OneWay, Converter={converters:DayOrTodayValueConverter}}"/>
                                                        <DropDownButton Grid.Column="1"
                                                                        Content="📅"
                                                                        ToolTip.Tip="{DynamicResource SetBegin}"
                                                                        Classes="TaskPlanningQuickAction"
                                                                        AutomationProperties.AutomationId="CurrentTaskSetBeginButton">
                                                            <DropDownButton.Flyout>
                                                                <MenuFlyout>
                                                                    <MenuItem Header="{DynamicResource Today}" Command="{Binding Commands.SetBeginToday}"/>
                                                                    <MenuItem Header="{DynamicResource Tomorrow}" Command="{Binding Commands.SetBeginTomorrow}"/>
                                                                    <MenuItem Header="{DynamicResource NextMonday}" Command="{Binding Commands.SetBeginNextMonday}"/>
                                                                    <MenuItem Header="{DynamicResource FirstDayNextMonth}" Command="{Binding Commands.SetBegin1DayNextMonth}"/>
                                                                    <MenuItem Header="{DynamicResource None}" Command="{Binding Commands.SetBeginNone}"/>
                                                                </MenuFlyout>
                                                            </DropDownButton.Flyout>
                                                        </DropDownButton>
                                                    </Grid>
                                                </StackPanel>

                                                <StackPanel Classes="TaskPlanningGroup">
                                                    <Grid Classes="TaskPlanningFieldRow" ColumnDefinitions="*,Auto">
                                                        <TextBox ToolTip.Tip="{DynamicResource DurationExample}"
                                                                 Classes="TaskPlanningValueControl"
                                                                 AutomationProperties.AutomationId="CurrentTaskPlannedDurationTextBox"
                                                                 HorizontalAlignment="Stretch"
                                                                 behavior:LostFocusUpdateBindingBehavior.Text="{Binding PlannedDuration, Converter={StaticResource TimeSpanStringConverter}}"
                                                                 PlaceholderText="{DynamicResource PlannedDuration}"
                                                                 UseFloatingPlaceholder="True"/>
                                                        <DropDownButton Grid.Column="1"
                                                                        Content="⏱"
                                                                        ToolTip.Tip="{DynamicResource SetDuration}"
                                                                        Classes="TaskPlanningQuickAction"
                                                                        AutomationProperties.AutomationId="CurrentTaskSetDurationButton">
                                                            <DropDownButton.Flyout>
                                                                <MenuFlyout>
                                                                    <MenuItem Header="{DynamicResource OneMinute}" Command="{Binding SetDurationCommands.OneMinCommand}" />
                                                                    <MenuItem Header="{DynamicResource FiveMinutes}" Command="{Binding SetDurationCommands.FiveMinutesCommand}" />
                                                                    <MenuItem Header="{DynamicResource TenMinutes}" Command="{Binding SetDurationCommands.TenMinutesCommand}" />
                                                                    <MenuItem Header="{DynamicResource TwentyMinutes}" Command="{Binding SetDurationCommands.TwentyMinutesCommand}" />
                                                                    <MenuItem Header="{DynamicResource FortyMinutes}" Command="{Binding SetDurationCommands.FortyMinutesCommand}" />
                                                                    <MenuItem Header="{DynamicResource OneHour}" Command="{Binding SetDurationCommands.OneHourCommand}" />
                                                                    <MenuItem Header="{DynamicResource TwoHours}" Command="{Binding SetDurationCommands.TwoHoursCommand}" />
                                                                    <MenuItem Header="{DynamicResource FourHours}" Command="{Binding SetDurationCommands.FourHoursCommand}" />
                                                                    <MenuItem Header="{DynamicResource OneDay}" Command="{Binding SetDurationCommands.OneDayCommand}" />
                                                                    <MenuItem Header="{DynamicResource TwoDays}" Command="{Binding SetDurationCommands.TwoDaysCommand}" />
                                                                    <MenuItem Header="{DynamicResource FourDays}" Command="{Binding SetDurationCommands.FourDaysCommand}" />
                                                                    <MenuItem Header="{DynamicResource EightDays}" Command="{Binding SetDurationCommands.EightDaysCommand}" />
                                                                    <MenuItem Header="{DynamicResource None}" Command="{Binding SetDurationCommands.NoneCommand}" />
                                                                </MenuFlyout>
                                                            </DropDownButton.Flyout>
                                                        </DropDownButton>
                                                    </Grid>
                                                </StackPanel>

                                                <StackPanel Classes="TaskPlanningGroup">
                                                    <Grid Classes="TaskPlanningFieldRow" ColumnDefinitions="*,Auto">
                                                        <CalendarDatePicker SelectedDate="{Binding PlannedEndDateTime}"
                                                                            Classes="TaskPlanningValueControl"
                                                                            AutomationProperties.AutomationId="CurrentTaskPlannedEndPicker"
                                                                            IsTodayHighlighted="True"
                                                                            PlaceholderText="{DynamicResource PlannedEnd}"
                                                                            UseFloatingPlaceholder="True"
                                                                            HorizontalAlignment="Stretch"
                                                                            DisplayDate="{Binding PlannedEndDateTime, Mode=OneWay, Converter={converters:DayOrTodayValueConverter}}"/>
                                                        <DropDownButton Grid.Column="1"
                                                                        Content="🏁"
                                                                        ToolTip.Tip="{DynamicResource SetEnd}"
                                                                        Classes="TaskPlanningQuickAction"
                                                                        AutomationProperties.AutomationId="CurrentTaskSetEndButton">
                                                            <DropDownButton.Flyout>
                                                                <MenuFlyout>
                                                                    <MenuItem Header="{DynamicResource Today}" Command="{Binding Commands.SetEndToday}"/>
                                                                    <MenuItem Header="{DynamicResource Tomorrow}" Command="{Binding Commands.SetEndTomorrow}"/>
                                                                    <MenuItem Header="{DynamicResource NextFriday}" Command="{Binding Commands.SetEndNextFriday}"/>
                                                                    <MenuItem Header="{DynamicResource OneDay}" Command="{Binding Commands.SetEnd1Days}"/>
                                                                    <MenuItem Header="{DynamicResource FiveDays}" Command="{Binding Commands.SetEnd5Days}"/>
                                                                    <MenuItem Header="{DynamicResource SevenDays}" Command="{Binding Commands.SetEnd7Days}"/>
                                                                    <MenuItem Header="{DynamicResource TenDays}" Command="{Binding Commands.SetEnd10Days}"/>
                                                                    <MenuItem Header="{DynamicResource OneMonth}" Command="{Binding Commands.SetEnd1Month}"/>
                                                                    <MenuItem Header="{DynamicResource None}" Command="{Binding Commands.SetEndNone}"/>
                                                                </MenuFlyout>
                                                            </DropDownButton.Flyout>
                                                        </DropDownButton>
                                                    </Grid>
                                                </StackPanel>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="TaskCardSection"
                                            AutomationProperties.ControlTypeOverride="Group"
                                            AutomationProperties.IsControlElementOverride="True"
                                            AutomationProperties.AutomationId="CurrentTaskRepeaterSection">
                                        <StackPanel Classes="TaskCardSectionContent">
                                            <WrapPanel Classes="RepeaterControls">
                                                <ComboBox Classes="RepeaterSelector"
                                                          ItemsSource="{Binding Repeaters}"
                                                          SelectedItem="{Binding Repeater}"
                                                          PlaceholderText="{DynamicResource RepeaterTemplates}"
                                                          AutomationProperties.AutomationId="CurrentTaskRepeaterSelector">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="viewModel:RepeaterPatternViewModel">
                                                            <Label Content="{Binding Title}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <Border Classes="RepeaterPatternHost"
                                                        IsVisible="{Binding IsHaveRepeater}">
                                                    <WrapPanel Classes="RepeaterPatternControls"
                                                               DataContext="{Binding Repeater}">
                                                        <ComboBox Classes="RepeaterPatternTypeSelector"
                                                                  ItemsSource="{Binding RepeaterTypes}"
                                                                  SelectedItem="{Binding SelectedRepeaterType}"
                                                                  AutomationProperties.AutomationId="CurrentTaskRepeaterPatternTypeSelector"/>
                                                        <NumericUpDown Classes="RepeaterPeriodInput"
                                                                       Value="{Binding Period}"
                                                                       PlaceholderText="{DynamicResource Period}"
                                                                       ToolTip.Tip="{DynamicResource Period}"
                                                                       AutomationProperties.AutomationId="CurrentTaskRepeaterPeriodInput"/>
                                                        <CheckBox Classes="RepeaterAfterCompleteCheckBox"
                                                                  IsChecked="{Binding AfterComplete}"
                                                                  Content="{DynamicResource AfterComplete}"
                                                                  AutomationProperties.AutomationId="CurrentTaskRepeaterAfterCompleteCheckBox"/>
                                                        <WrapPanel Classes="WeekdayToggles"
                                                                   IsVisible="{Binding Type, Converter={StaticResource EqualConverter}, ConverterParameter={x:Static domain:RepeaterType.Weekly}, FallbackValue={x:Static domain:RepeaterType.None}}">
                                                            <ToggleButton Classes="WeekdayToggle" IsChecked="{Binding Monday}" Content="{DynamicResource MondayShort}" ToolTip.Tip="{DynamicResource Monday}" />
                                                            <ToggleButton Classes="WeekdayToggle" IsChecked="{Binding Tuesday}" Content="{DynamicResource TuesdayShort}" ToolTip.Tip="{DynamicResource Tuesday}" />
                                                            <ToggleButton Classes="WeekdayToggle" IsChecked="{Binding Wednesday}" Content="{DynamicResource WednesdayShort}" ToolTip.Tip="{DynamicResource Wednesday}"/>
                                                            <ToggleButton Classes="WeekdayToggle" IsChecked="{Binding Thursday}" Content="{DynamicResource ThursdayShort}" ToolTip.Tip="{DynamicResource Thursday}" />
                                                            <ToggleButton Classes="WeekdayToggle" IsChecked="{Binding Friday}" Content="{DynamicResource FridayShort}" ToolTip.Tip="{DynamicResource Friday}" />
                                                            <ToggleButton Classes="WeekdayToggle" IsChecked="{Binding Saturday}" Content="{DynamicResource SaturdayShort}" ToolTip.Tip="{DynamicResource Saturday}" />
                                                            <ToggleButton Classes="WeekdayToggle" IsChecked="{Binding Sunday}" Content="{DynamicResource SundayShort}" ToolTip.Tip="{DynamicResource Sunday}" />
                                                        </WrapPanel>
                                                    </WrapPanel>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="TaskCardSection"
                                            AutomationProperties.ControlTypeOverride="Group"
                                            AutomationProperties.IsControlElementOverride="True"
                                            AutomationProperties.AutomationId="CurrentTaskRelationsSection">
                                        <StackPanel Classes="TaskCardSectionContent">
                                    <Grid Classes="RelationSectionHeader" ColumnDefinitions="*,Auto">
                                        <Label Content="{DynamicResource ParentsTasks}"/>
                                        <Button Grid.Column="1"
                                                Classes="RelationAddButton"
                                                Content="＋"
                                                ToolTip.Tip="{DynamicResource Add}"
                                                Click="RelationAddButton_OnClick"
                                                Tag="Parents"
                                                AutomationProperties.AutomationId="CurrentTaskParentsRelationAddButton"/>
                                    </Grid>
                                    <Border Classes="RelationEditorCard"
                                            DataContext="{Binding MainWindow.CurrentRelationEditor}"
                                            IsVisible="{Binding IsOpenForParents}">
                                        <StackPanel Classes="RelationPickerRow">
                                            <TextBlock Text="{Binding Header}" FontWeight="Bold"/>
                                            <TextBox Classes="RelationEditorSearch"
                                                     Text="{Binding Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PlaceholderText="{Binding Watermark}"
                                                     KeyDown="RelationEditorControl_OnKeyDown"
                                                     AutomationProperties.AutomationId="CurrentTaskParentsRelationAddInput"/>
                                            <ListBox Classes="RelationEditorSuggestions"
                                                     ItemsSource="{Binding Suggestions}"
                                                     SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}"
                                                     DoubleTapped="RelationEditorSuggestions_OnDoubleTapped"
                                                     KeyDown="RelationEditorControl_OnKeyDown"
                                                     AutomationProperties.AutomationId="CurrentTaskParentsRelationSuggestions"/>
                                            <TextBlock Text="{Binding EmptyStateText}"
                                                       IsVisible="{Binding !HasSuggestions}"
                                                       Opacity="0.7"
                                                       TextWrapping="Wrap"/>
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8" HorizontalAlignment="Right">
                                                <Button Content="{DynamicResource Cancel}"
                                                        Command="{Binding CancelCommand}"
                                                        AutomationProperties.AutomationId="CurrentTaskParentsRelationAddCancelButton"/>
                                                <Button Grid.Column="1"
                                                        Content="{DynamicResource Add}"
                                                        Command="{Binding ConfirmCommand}"
                                                        AutomationProperties.AutomationId="CurrentTaskParentsRelationAddConfirmButton"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    <TreeView DataContext="{Binding MainWindow}"
                                              ItemsSource="{Binding CurrentItemParents.SubTasks}"
                                              SelectionMode="Multiple"
                                              Classes="TaskTree RelationTaskTree"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              PointerPressed="TaskTree_OnPointerPressed"
                                              AutomationProperties.AutomationId="CurrentItemParentsTree"
                                              x:Name="CurrentItemParentsTree">
                                        <TreeView.ItemTemplate>
                                            <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                                <ContentControl Content="{Binding .}" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased" DoubleTapped="Task_OnDoubleTapped"/>
                                            </TreeDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>

                                    <Grid Classes="RelationSectionHeader" ColumnDefinitions="*,Auto">
                                        <Label Content="{DynamicResource BlockingTasks}"/>
                                        <Button Grid.Column="1"
                                                Classes="RelationAddButton"
                                                Content="＋"
                                                ToolTip.Tip="{DynamicResource Add}"
                                                Click="RelationAddButton_OnClick"
                                                Tag="Blocking"
                                                AutomationProperties.AutomationId="CurrentTaskBlockingRelationAddButton"/>
                                    </Grid>
                                    <Border Classes="RelationEditorCard"
                                            DataContext="{Binding MainWindow.CurrentRelationEditor}"
                                            IsVisible="{Binding IsOpenForBlocking}">
                                        <StackPanel Classes="RelationPickerRow">
                                            <TextBlock Text="{Binding Header}" FontWeight="Bold"/>
                                            <TextBox Classes="RelationEditorSearch"
                                                     Text="{Binding Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PlaceholderText="{Binding Watermark}"
                                                     KeyDown="RelationEditorControl_OnKeyDown"
                                                     AutomationProperties.AutomationId="CurrentTaskBlockingRelationAddInput"/>
                                            <ListBox Classes="RelationEditorSuggestions"
                                                     ItemsSource="{Binding Suggestions}"
                                                     SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}"
                                                     DoubleTapped="RelationEditorSuggestions_OnDoubleTapped"
                                                     KeyDown="RelationEditorControl_OnKeyDown"
                                                     AutomationProperties.AutomationId="CurrentTaskBlockingRelationSuggestions"/>
                                            <TextBlock Text="{Binding EmptyStateText}"
                                                       IsVisible="{Binding !HasSuggestions}"
                                                       Opacity="0.7"
                                                       TextWrapping="Wrap"/>
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8" HorizontalAlignment="Right">
                                                <Button Content="{DynamicResource Cancel}"
                                                        Command="{Binding CancelCommand}"
                                                        AutomationProperties.AutomationId="CurrentTaskBlockingRelationAddCancelButton"/>
                                                <Button Grid.Column="1"
                                                        Content="{DynamicResource Add}"
                                                        Command="{Binding ConfirmCommand}"
                                                        AutomationProperties.AutomationId="CurrentTaskBlockingRelationAddConfirmButton"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    <TreeView DataContext="{Binding MainWindow}"
                                              ItemsSource="{Binding CurrentItemBlockedBy.SubTasks}"
                                              SelectionMode="Multiple"
                                              Classes="TaskTree RelationTaskTree"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              PointerPressed="TaskTree_OnPointerPressed"
                                              AutomationProperties.AutomationId="CurrentItemBlockedByTree"
                                              x:Name="CurrentItemBlockedByTree">
                                        <TreeView.ItemTemplate>
                                            <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                                <ContentControl Content="{Binding .}" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased" DoubleTapped="Task_OnDoubleTapped"/>
                                            </TreeDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>

                                    <Grid Classes="RelationSectionHeader" ColumnDefinitions="*,Auto">
                                        <Label Content="{DynamicResource ContainingTasks}"/>
                                        <Button Grid.Column="1"
                                                Classes="RelationAddButton"
                                                Content="＋"
                                                ToolTip.Tip="{DynamicResource Add}"
                                                Click="RelationAddButton_OnClick"
                                                Tag="Containing"
                                                AutomationProperties.AutomationId="CurrentTaskContainingRelationAddButton"/>
                                    </Grid>
                                    <Border Classes="RelationEditorCard"
                                            DataContext="{Binding MainWindow.CurrentRelationEditor}"
                                            IsVisible="{Binding IsOpenForContaining}">
                                        <StackPanel Classes="RelationPickerRow">
                                            <TextBlock Text="{Binding Header}" FontWeight="Bold"/>
                                            <TextBox Classes="RelationEditorSearch"
                                                     Text="{Binding Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PlaceholderText="{Binding Watermark}"
                                                     KeyDown="RelationEditorControl_OnKeyDown"
                                                     AutomationProperties.AutomationId="CurrentTaskContainingRelationAddInput"/>
                                            <ListBox Classes="RelationEditorSuggestions"
                                                     ItemsSource="{Binding Suggestions}"
                                                     SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}"
                                                     DoubleTapped="RelationEditorSuggestions_OnDoubleTapped"
                                                     KeyDown="RelationEditorControl_OnKeyDown"
                                                     AutomationProperties.AutomationId="CurrentTaskContainingRelationSuggestions"/>
                                            <TextBlock Text="{Binding EmptyStateText}"
                                                       IsVisible="{Binding !HasSuggestions}"
                                                       Opacity="0.7"
                                                       TextWrapping="Wrap"/>
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8" HorizontalAlignment="Right">
                                                <Button Content="{DynamicResource Cancel}"
                                                        Command="{Binding CancelCommand}"
                                                        AutomationProperties.AutomationId="CurrentTaskContainingRelationAddCancelButton"/>
                                                <Button Grid.Column="1"
                                                        Content="{DynamicResource Add}"
                                                        Command="{Binding ConfirmCommand}"
                                                        AutomationProperties.AutomationId="CurrentTaskContainingRelationAddConfirmButton"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    <TreeView DataContext="{Binding MainWindow}"
                                              ItemsSource="{Binding CurrentItemContains.SubTasks}"
                                              SelectionMode="Multiple"
                                              Classes="TaskTree RelationTaskTree"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              PointerPressed="TaskTree_OnPointerPressed"
                                              AutomationProperties.AutomationId="CurrentItemContainsTree"
                                              x:Name="CurrentItemContainsTree">
                                        <TreeView.ItemTemplate>
                                            <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                                <ContentControl Content="{Binding .}" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased" DoubleTapped="Task_OnDoubleTapped"/>
                                            </TreeDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>

                                    <Grid Classes="RelationSectionHeader" ColumnDefinitions="*,Auto">
                                        <Label Content="{DynamicResource BlockedTasks}"/>
                                        <Button Grid.Column="1"
                                                Classes="RelationAddButton"
                                                Content="＋"
                                                ToolTip.Tip="{DynamicResource Add}"
                                                Click="RelationAddButton_OnClick"
                                                Tag="Blocked"
                                                AutomationProperties.AutomationId="CurrentTaskBlockedRelationAddButton"/>
                                    </Grid>
                                    <Border Classes="RelationEditorCard"
                                            DataContext="{Binding MainWindow.CurrentRelationEditor}"
                                            IsVisible="{Binding IsOpenForBlocked}">
                                        <StackPanel Classes="RelationPickerRow">
                                            <TextBlock Text="{Binding Header}" FontWeight="Bold"/>
                                            <TextBox Classes="RelationEditorSearch"
                                                     Text="{Binding Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PlaceholderText="{Binding Watermark}"
                                                     KeyDown="RelationEditorControl_OnKeyDown"
                                                     AutomationProperties.AutomationId="CurrentTaskBlockedRelationAddInput"/>
                                            <ListBox Classes="RelationEditorSuggestions"
                                                     ItemsSource="{Binding Suggestions}"
                                                     SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}"
                                                     DoubleTapped="RelationEditorSuggestions_OnDoubleTapped"
                                                     KeyDown="RelationEditorControl_OnKeyDown"
                                                     AutomationProperties.AutomationId="CurrentTaskBlockedRelationSuggestions"/>
                                            <TextBlock Text="{Binding EmptyStateText}"
                                                       IsVisible="{Binding !HasSuggestions}"
                                                       Opacity="0.7"
                                                       TextWrapping="Wrap"/>
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8" HorizontalAlignment="Right">
                                                <Button Content="{DynamicResource Cancel}"
                                                        Command="{Binding CancelCommand}"
                                                        AutomationProperties.AutomationId="CurrentTaskBlockedRelationAddCancelButton"/>
                                                <Button Grid.Column="1"
                                                        Content="{DynamicResource Add}"
                                                        Command="{Binding ConfirmCommand}"
                                                        AutomationProperties.AutomationId="CurrentTaskBlockedRelationAddConfirmButton"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    <TreeView DataContext="{Binding MainWindow}"
                                              ItemsSource="{Binding CurrentItemBlocks.SubTasks}"
                                              SelectionMode="Multiple"
                                              Classes="TaskTree RelationTaskTree"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              PointerPressed="TaskTree_OnPointerPressed"
                                              AutomationProperties.AutomationId="CurrentItemBlocksTree"
                                              x:Name="CurrentItemBlocksTree">
                                        <TreeView.ItemTemplate>
                                            <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                                <ContentControl Content="{Binding .}" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased" DoubleTapped="Task_OnDoubleTapped"/>
                                            </TreeDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>

                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </SplitView.Pane>
        </SplitView>
        <!--Редактор задачи-->
    </Grid>

</UserControl>
