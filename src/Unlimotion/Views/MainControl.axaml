                                                <Label Grid.Column="1" Classes="TaskTreeMetaLabel" Content="{Binding TaskItem.UpdatedDateTime, StringFormat={}{0:yyyy.MM.dd}}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <Label Grid.Column="2" Content="{Binding TaskItem.GetAllEmoji}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TaskItem.RepeaterListMarker}"
                                                           IsVisible="{Binding TaskItem.IsHaveRepeater}"
