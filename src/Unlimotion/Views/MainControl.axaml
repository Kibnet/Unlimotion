                                                                    AutomationProperties.Name="{DynamicResource ResetFilters}"
                                                                    Command="{Binding ResetTaskFiltersCommand}"
                                                                    AutomationProperties.AutomationId="InProgressResetFiltersButton">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <PathIcon Classes="FilterPanelResetIcon" Width="16" Height="16" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.82,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                                                                    <TextBlock Text="{DynamicResource ResetFilters}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Flyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                </WrapPanel>
                                <searchControl:SearchBar Grid.Column="1" Classes="FilterToolbarSearch" DataContext="{Binding Search}"/>
                            </Grid>
                            <TreeView Grid.Row="1" AutoScrollToSelectedItem="True"
                                      ItemsSource="{Binding InProgressItems}"
                                      SelectedItem="{Binding CurrentInProgressItem}"
                                      SelectionMode="Multiple"
                                      Classes="TaskTree"
                                      PointerPressed="TaskTree_OnPointerPressed"
                                      KeyDown="TaskTree_OnKeyDown"
                                      AutomationProperties.AutomationId="InProgressTree"
                                      x:Name="InProgressTree">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                        <Grid DoubleTapped="TaskTree_OnDoubleTapped" Background="Transparent">
                                            <Grid ColumnDefinitions="Auto, Auto, Auto, Auto, Auto,*" DragDrop.AllowDrop="True" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased">
                                                <unlimotion:TaskStatusPicker Task="{Binding TaskItem}" VerticalAlignment="Center" AutomationProperties.AutomationId="TaskStatusButton" />
                                                <Label Grid.Column="1"
                                                       Classes="TaskTreeMetaLabel"
                                                       Content="{Binding TaskItem.StartedLocalDateTime, StringFormat={}{0:yyyy.MM.dd HH:mm}}"
                                                       Foreground="{StaticResource AccentButtonBackground}"
                                                       FontFamily="Consolas"
                                                       VerticalAlignment="Center"
                                                       AutomationProperties.AutomationId="InProgressStartedDateLabel" />
                                                <Label Grid.Column="2" Classes="TaskTreeMetaLabel" Content="{Binding TaskItem.InProgressElapsed}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" AutomationProperties.AutomationId="InProgressElapsedLabel" />
                                                <Label Grid.Column="3" Content="{Binding TaskItem.GetAllEmoji}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding TaskItem.RepeaterListMarker}"
                                                           IsVisible="{Binding TaskItem.IsHaveRepeater}"
                                                           ToolTip.Tip="{Binding TaskItem.RepeaterListMarkerToolTip}"
                                                           AutomationProperties.AutomationId="TaskRepeaterListMarker"
                                                           Margin="4,0,4,0"
                                                           VerticalAlignment="Center" />
                                                <Grid Grid.Column="5" VerticalAlignment="Center">
                                                    <unlimotion:EmojiTextBlock EmojiText="{Binding TaskItem.Title}" VerticalAlignment="Center" HorizontalAlignment="Left" AutomationProperties.AutomationId="InlineTaskTitleTextBlock" Classes.IsWanted="{Binding TaskItem.Wanted}" PointerPressed="InlineTaskTitleText_OnPointerPressed"/>
                                                </Grid>
                                            </Grid>
                                            <Button Classes="TaskRowRemoveButton"
                                                    ToolTip.Tip="{DynamicResource Remove}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding RemoveCommand}">
                                                <PathIcon Classes="RemoveButtonIcon" Data="M15.5,5.9 L14.1,4.5 L10,8.6 L5.9,4.5 L4.5,5.9 L8.6,10 L4.5,14.1 L5.9,15.5 L10,11.4 L14.1,15.5 L15.5,14.1 L11.4,10 Z"/>
                                            </Button>
                                        </Grid>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Completed-->
                    <TabItem Header="{DynamicResource Completed}" IsSelected="{Binding CompletedMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="CompletedTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
                                    <views:EmojiFilterMultiSelectSearchBox Filters="{Binding EmojiFilters}"
                                                                           Watermark="{DynamicResource EmojiFilterSearchWatermark}"
                                                                           NoMatchesText="{DynamicResource EmojiFilterNoMatches}"
                                                                           SummaryWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryWidth}"
                                                                           SummaryMinWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryMinWidth}"
                                                                           SummaryAutomationId="IncludeEmojiFilterSummaryBox"
                                                                           SearchAutomationId="IncludeEmojiFilterSearchBox"
                                                                           DropDownAutomationId="IncludeEmojiFilterDropDown"
                                                                           ListAutomationId="IncludeEmojiFilterList"
                                                                           NoMatchesAutomationId="IncludeEmojiFilterNoMatches"/>
                                    <views:EmojiFilterMultiSelectSearchBox Filters="{Binding EmojiExcludeFilters}"
                                                                           Watermark="{DynamicResource EmojiExcludeFilterSearchWatermark}"
                                                                           NoMatchesText="{DynamicResource EmojiFilterNoMatches}"
                                                                           IsExclude="True"
                                                                           SummaryWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryWidth}"
                                                                           SummaryMinWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryMinWidth}"
                                                                           SummaryAutomationId="ExcludeEmojiFilterSummaryBox"
                                                                           SearchAutomationId="ExcludeEmojiFilterSearchBox"
                                                                           DropDownAutomationId="ExcludeEmojiFilterDropDown"
                                                                           ListAutomationId="ExcludeEmojiFilterList"
                                                                           NoMatchesAutomationId="ExcludeEmojiFilterNoMatches"/>
                                    <DropDownButton Classes="FilterToolbarFiltersButton"
                                                    ToolTip.Tip="{DynamicResource Filters}"
                                                    AutomationProperties.Name="{DynamicResource Filters}"
                                                    Margin="0"
                                                    AutomationProperties.AutomationId="CompletedFiltersButton">
                                        <PathIcon Classes="FilterToolbarFiltersIcon" Width="15" Height="15" Data="M3,5 L21,5 L21,7 L3,7 Z M7,11 L17,11 L17,13 L7,13 Z M10,17 L14,17 L14,19 L10,19 Z"/>
                                        <DropDownButton.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Classes="FilterOverflowPanel"
                                                        MinWidth="0"
                                                        MaxWidth="360"
                                                        AutomationProperties.AutomationId="CompletedFilterPanel">
                                                    <ScrollViewer Classes="FilterPanelScrollViewer">
                                                    <StackPanel Spacing="10">
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterState}"/>
                                                            <WrapPanel>
                                                                <ComboBox ItemsSource="{Binding CompletedStatusFilters}" MinWidth="220" Margin="0,0,8,6" AutomationProperties.AutomationId="CompletedStatusFilterComboBox"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterDate}"/>
                                                            <WrapPanel>
                                                                <CheckBox Content="{DynamicResource CustomPeriod}" IsChecked="{Binding CompletedDateFilter.IsCustom}" Margin="0,0,12,6" VerticalAlignment="Center"/>
                                                                <ComboBox IsVisible="{Binding !CompletedDateFilter.IsCustom}" ItemsSource="{Binding DateFilterDefinitions}" SelectedItem="{Binding CompletedDateFilter.CurrentOption}" VerticalAlignment="Center" Margin="0,0,8,6" />
                                                            </WrapPanel>
                                                            <WrapPanel IsVisible="{Binding CompletedDateFilter.IsCustom}">
                                                                <Label Content="{DynamicResource From}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding CompletedDateFilter.From}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding CompletedDateFilter.From, Converter={converters:DayOrTodayValueConverter}}"/>
                                                                <Label Content="{DynamicResource To}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding CompletedDateFilter.To}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding CompletedDateFilter.To, Converter={converters:DayOrTodayValueConverter}}"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <Button Classes="FilterPanelResetButton"
                                                                ToolTip.Tip="{DynamicResource ResetFilters}"
                                                                AutomationProperties.Name="{DynamicResource ResetFilters}"
                                                                Command="{Binding ResetTaskFiltersCommand}"
                                                                AutomationProperties.AutomationId="CompletedResetFiltersButton">
                                                            <StackPanel Orientation="Horizontal">
                                                                <PathIcon Classes="FilterPanelResetIcon" Width="16" Height="16" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.82,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                                                                <TextBlock Text="{DynamicResource ResetFilters}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Flyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                </WrapPanel>
                                <searchControl:SearchBar Grid.Column="1" Classes="FilterToolbarSearch" DataContext="{Binding Search}"/>
                            </Grid>
                            <TreeView Grid.Row="1" AutoScrollToSelectedItem="True"
                                      ItemsSource="{Binding CompletedItems}"
                                      SelectedItem="{Binding CurrentCompletedItem}"
                                      SelectionMode="Multiple"
                                      Classes="TaskTree"
                                      PointerPressed="TaskTree_OnPointerPressed"
                                      KeyDown="TaskTree_OnKeyDown"
                                      AutomationProperties.AutomationId="CompletedTree"
                                      x:Name="CompletedTree">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                        <Grid DoubleTapped="TaskTree_OnDoubleTapped" Background="Transparent">
                                            <Grid ColumnDefinitions="Auto, Auto, Auto, Auto,*" DragDrop.AllowDrop="True" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased">
                                                <unlimotion:TaskStatusPicker Task="{Binding TaskItem}" VerticalAlignment="Center" AutomationProperties.AutomationId="TaskStatusButton" />
                                                <Label Grid.Column="1" Classes="TaskTreeMetaLabel" Content="{Binding TaskItem.CompletedDateTime, StringFormat={}{0:yyyy.MM.dd}}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <Label Grid.Column="1" Classes="TaskTreeMetaLabel" Content="{Binding TaskItem.ArchiveDateTime, StringFormat={}{0:yyyy.MM.dd}}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <Label Grid.Column="2" Content="{Binding TaskItem.GetAllEmoji}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TaskItem.RepeaterListMarker}"
                                                           IsVisible="{Binding TaskItem.IsHaveRepeater}"
                                                           ToolTip.Tip="{Binding TaskItem.RepeaterListMarkerToolTip}"
                                                           AutomationProperties.AutomationId="TaskRepeaterListMarker"
                                                           Margin="4,0,4,0"
                                                           VerticalAlignment="Center" />
                                                <Grid Grid.Column="4" VerticalAlignment="Center">
                                                    <unlimotion:EmojiTextBlock EmojiText="{Binding TaskItem.Title}" VerticalAlignment="Center" HorizontalAlignment="Left" AutomationProperties.AutomationId="InlineTaskTitleTextBlock" Classes.IsWanted="{Binding TaskItem.Wanted}" PointerPressed="InlineTaskTitleText_OnPointerPressed"/>
                                                </Grid>
                                            </Grid>
                                            <Button Classes="TaskRowRemoveButton"
                                                    ToolTip.Tip="{DynamicResource Remove}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding RemoveCommand}">
                                                <PathIcon Classes="RemoveButtonIcon" Data="M15.5,5.9 L14.1,4.5 L10,8.6 L5.9,4.5 L4.5,5.9 L8.6,10 L4.5,14.1 L5.9,15.5 L10,11.4 L14.1,15.5 L15.5,14.1 L11.4,10 Z"/>
                                            </Button>
                                        </Grid>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Archived-->
                    <TabItem Header="{DynamicResource Archived}" IsSelected="{Binding ArchivedMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="ArchivedTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
