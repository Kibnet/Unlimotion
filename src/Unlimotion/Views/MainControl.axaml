                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Last Opened-->
                    <TabItem Header="{DynamicResource LastOpened}" IsSelected="{Binding LastOpenedMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="LastOpenedTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
                                    <DropDownButton Classes="FilterToolbarFiltersButton"
                                                    ToolTip.Tip="{DynamicResource Filters}"
                                                    AutomationProperties.Name="{DynamicResource Filters}"
                                                    Margin="0"
                                                    AutomationProperties.AutomationId="LastOpenedFiltersButton">
                                        <PathIcon Classes="FilterToolbarFiltersIcon" Width="15" Height="15" Data="M3,5 L21,5 L21,7 L3,7 Z M7,11 L17,11 L17,13 L7,13 Z M10,17 L14,17 L14,19 L10,19 Z"/>
                                        <DropDownButton.Flyout>
