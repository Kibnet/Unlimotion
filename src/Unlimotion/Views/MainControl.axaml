<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModel="clr-namespace:Unlimotion.ViewModel;assembly=Unlimotion.ViewModel"
             xmlns:unlimotion="clr-namespace:Unlimotion"
             xmlns:views="clr-namespace:Unlimotion.Views"
             xmlns:converters="clr-namespace:Unlimotion.Converters"
             xmlns:behavior="clr-namespace:Unlimotion.Behavior"
             xmlns:domain="clr-namespace:Unlimotion.Domain;assembly=Unlimotion.Domain"
             xmlns:searchControl="clr-namespace:Unlimotion.Views.SearchControl"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="viewModel:MainWindowViewModel"
             Name="mainControl"
             x:Class="Unlimotion.Views.MainControl">

    <Design.DataContext>
        <viewModel:MainWindowViewModel/>
    </Design.DataContext>
    <UserControl.Resources>
        <SolidColorBrush x:Key="CurrentTaskDetailsPanelBackgroundBrush" Color="{DynamicResource SystemChromeLowColor}"/>
        <SolidColorBrush x:Key="CurrentTaskDetailsPanelBorderBrush" Color="{DynamicResource SystemBaseMediumColor}"/>
        <unlimotion:TimeSpanStringConverter x:Key="TimeSpanStringConverter"/>
        <unlimotion:EqualConverter x:Key="EqualConverter"/>
        <unlimotion:NotEqualConverter x:Key="NotEqualConverter"/>
        <DataTemplate x:Key="TaskStatusOptionDropDownTemplate" DataType="viewModel:TaskStatusOption">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" MinHeight="24">
                <unlimotion:TaskStatusIcon Status="{Binding Status}"
                                           Width="20"
                                           Height="20"
                                           VerticalAlignment="Center"
                                           IsEnabled="{Binding IsEnabled}"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           VerticalAlignment="Center"
                           IsEnabled="{Binding IsEnabled}"
                           ToolTip.Tip="{Binding ToolTip}"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="Button.TaskStatusPicker">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="MinWidth" Value="20"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.TaskStatusPicker:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TreeView.TaskTree Label">
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TreeView.TaskTree Label.TaskTreeMetaLabel">
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>
        <Style Selector="Expander.TaskStatusHistoryExpander">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid MinWidth="{TemplateBinding MinWidth}"
                          MaxWidth="{TemplateBinding MaxWidth}"
                          RowDefinitions="Auto,Auto">
                        <ToggleButton x:Name="PART_HeaderSite"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Left"
                                      Content="{TemplateBinding Header}"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      IsEnabled="{TemplateBinding IsEnabled}"
                                      IsChecked="{TemplateBinding IsExpanded, Mode=TwoWay}"/>
                        <Border Grid.Row="1"
                                x:Name="ExpanderContent"
                                IsVisible="{TemplateBinding IsExpanded}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,0,1,1"
                                MinHeight="{TemplateBinding MinHeight}"
                                HorizontalAlignment="Stretch"
                                Padding="8">
                            <ContentPresenter x:Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Grid.FilterToolbar">
            <Setter Property="ColumnSpacing" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="WrapPanel.FilterToolbarItems">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style Selector="searchControl|SearchBar.FilterToolbarSearch">
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Border.FilterOverflowPanel">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="ScrollViewer.FilterPanelScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style Selector="TextBlock.FilterPanelGroupTitle">
            <Setter Property="FontSize" Value="{DynamicResource AppSmallFontSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Button.FilterPanelResetButton">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="DropDownButton.FilterToolbarFiltersButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="{DynamicResource AppSearchControlHeight}"/>
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="MinHeight" Value="{DynamicResource AppSearchControlHeight}"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="PathIcon.FilterToolbarFiltersIcon">
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <Style Selector="PathIcon.FilterPanelResetIcon">
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel">
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Spacing" Value="8"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Spacing" Value="6"/>
        </Style>
        <Style Selector="Border.CurrentTaskDetailsPanelFrame">
            <Setter Property="Background" Value="{DynamicResource CurrentTaskDetailsPanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CurrentTaskDetailsPanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="WrapPanel.TaskCommandBar">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,4"/>
        </Style>
        <Style Selector="Button.TaskCommandButton">
            <Setter Property="Margin" Value="0,0,6,4"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style Selector="Button.TaskCommandPrimaryButton">
            <Setter Property="Background" Value="{DynamicResource AccentButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonBackground}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.TaskCommandSecondaryButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.TaskCommandDangerButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B3261E"/>
            <Setter Property="BorderBrush" Value="#66B3261E"/>
        </Style>
        <Style Selector="DropDownButton.TaskCommandOverflowButton">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,6,4"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style Selector="DropDownButton.TaskAccentOutlineButton">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentButtonBackground}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeControlLowBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonBackground}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.TaskAccentOutlineButton">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentButtonBackground}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeControlLowBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonBackground}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="DropDownButton.TaskIconOnlyDropDownButton">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="DropDownButton.TaskAccentOutlineButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource ThemeControlMidBrush}"/>
        </Style>
        <Style Selector="Button.TaskAccentOutlineButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource ThemeControlMidBrush}"/>
        </Style>
        <Style Selector="DropDownButton.TaskActionsMenuButton">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="FontSize" Value="17"/>
        </Style>
        <Style Selector="DropDownButton.TaskCreateMenuButton">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="MenuItem.TaskCreateMenuItem">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact Button.TaskCommandSecondaryButton">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact DropDownButton.TaskCommandOverflowButton">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
        <Style Selector="Button.MainTabsOverflowButton">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="{DynamicResource AppTabMinHeight}"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style Selector="Button.MainTabsOverflowButton:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.MainTabsOverflowButton:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Border.CurrentTaskCard">
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact Border.CurrentTaskCard">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="StackPanel.CurrentTaskCardContent">
            <Setter Property="Spacing" Value="8"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact StackPanel.CurrentTaskCardContent">
            <Setter Property="Spacing" Value="6"/>
        </Style>
        <Style Selector="Grid.TaskCardHeader">
            <Setter Property="ColumnSpacing" Value="6"/>
            <Setter Property="RowSpacing" Value="6"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact Grid.TaskCardHeader">
            <Setter Property="ColumnSpacing" Value="6"/>
            <Setter Property="RowSpacing" Value="6"/>
        </Style>
        <Style Selector="CheckBox.TaskHeaderCompletionCheckBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="WrapPanel.TaskHeaderStateRow">
            <Setter Property="Orientation" Value="Horizontal"/>
        </Style>
        <Style Selector="CheckBox.TaskHeaderStateCheckBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,4"/>
        </Style>
        <Style Selector="NumericUpDown.TaskHeaderImportanceInput">
            <Setter Property="Width" Value="86"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,4"/>
        </Style>
        <Style Selector="WrapPanel.TaskHeaderMetaRow">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Opacity" Value="0.78"/>
        </Style>
        <Style Selector="TextBlock.TaskHeaderIdMeta">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="FontSize" Value="{DynamicResource AppSmallFontSize}"/>
            <Setter Property="Margin" Value="0,0,8,4"/>
            <Setter Property="MinHeight" Value="22"/>
        </Style>
        <Style Selector="WrapPanel.TaskHeaderDateMeta">
            <Setter Property="Margin" Value="0,0,8,4"/>
        </Style>
        <Style Selector="WrapPanel.TaskHeaderDateMeta Label">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="{DynamicResource AppSmallFontSize}"/>
        </Style>
        <Style Selector="TextBox.CurrentTaskTitleEditor">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.BorderlessTextBoxChrome">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.BorderlessTextBoxChrome /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.BorderlessTextBoxChrome:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.BorderlessTextBoxChrome:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.BorderlessTextBoxChrome:focus:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact TextBox.CurrentTaskTitleEditor">
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style Selector="Border.TaskCardSection">
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="0,5,0,0"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact Border.TaskCardSection">
            <Setter Property="Padding" Value="0,5,0,0"/>
        </Style>
        <Style Selector="StackPanel.TaskCardSectionContent">
            <Setter Property="Spacing" Value="5"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact StackPanel.TaskCardSectionContent">
            <Setter Property="Spacing" Value="4"/>
        </Style>
        <Style Selector="TextBlock.TaskCardSectionTitle">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="{DynamicResource AppSmallFontSize}"/>
            <Setter Property="Opacity" Value="0.78"/>
        </Style>
        <Style Selector="TextBox.TaskDescriptionEditor">
            <Setter Property="MinHeight" Value="82"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact TextBox.TaskDescriptionEditor">
            <Setter Property="MinHeight" Value="72"/>
        </Style>
        <Style Selector="WrapPanel.TaskPlanningGroups">
            <Setter Property="Orientation" Value="Horizontal"/>
        </Style>
        <Style Selector="StackPanel.TaskPlanningGroup">
            <Setter Property="Width" Value="176"/>
            <Setter Property="Margin" Value="0,0,4,5"/>
            <Setter Property="Spacing" Value="0"/>
        </Style>
        <Style Selector="Grid.TaskPlanningFieldRow">
            <Setter Property="ColumnSpacing" Value="4"/>
        </Style>
        <Style Selector="CalendarDatePicker.TaskPlanningValueControl">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="10,6,6,5"/>
        </Style>
        <Style Selector="TextBox.TaskPlanningValueControl">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>
        <Style Selector="DropDownButton.TaskPlanningQuickAction">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontSize" Value="17"/>
        </Style>
        <Style Selector="Grid.RepeaterControls">
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style Selector="Grid.RepeaterPatternControls">
            <Setter Property="ColumnSpacing" Value="0"/>
            <Setter Property="RowSpacing" Value="0"/>
        </Style>
        <Style Selector="ComboBox.RepeaterSelector">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,5"/>
        </Style>
        <Style Selector="ComboBox.RepeaterPatternTypeSelector">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,5"/>
        </Style>
        <Style Selector="NumericUpDown.RepeaterPeriodInput">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,5"/>
        </Style>
        <Style Selector="CheckBox.RepeaterAfterCompleteCheckBox">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,5"/>
        </Style>
        <Style Selector="WrapPanel.WeekdayToggles">
            <Setter Property="Orientation" Value="Horizontal"/>
        </Style>
        <Style Selector="ToggleButton.WeekdayToggle">
            <Setter Property="Width" Value="46"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Grid.RelationSectionHeader">
            <Setter Property="ColumnSpacing" Value="8"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>
        <Style Selector="Grid.RelationSectionHeader Label">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{DynamicResource AppSmallFontSize}"/>
            <Setter Property="Opacity" Value="0.76"/>
        </Style>
        <Style Selector="Button.RelationAddButton">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="StackPanel.RelationPickerRow">
            <Setter Property="Spacing" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="Border.RelationEditorCard">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#33000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="StackPanel.TaskDetailsPanel.TaskDetailsCompact Border.RelationEditorCard">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBox.RelationEditorSearch">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ListBox.RelationEditorSuggestions">
            <Setter Property="MaxHeight" Value="240"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor">
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor:focus">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor:focus:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.InlineTaskTitleEditor.IsWanted">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="TextBox.CompletionCriterionTextBox">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.TaskRowRemoveButton">
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#B3261E"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.CompletionCriterionRemoveButton">
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#B3261E"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="PathIcon.RemoveButtonIcon">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Foreground" Value="#B3261E"/>
        </Style>
        <Style Selector="TreeView.TaskTree">
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="{DynamicResource ExpandCurrentNested}"
                                  Tag="ExpandCurrentNested"
                                  InputGesture="Ctrl+Shift+Right"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="ExpandCurrentNestedTreeMenuItem"/>
                        <MenuItem Header="{DynamicResource CollapseCurrentNested}"
                                  Tag="CollapseCurrentNested"
                                  InputGesture="Ctrl+Shift+Left"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="CollapseCurrentNestedTreeMenuItem"/>
                        <MenuItem Header="{DynamicResource ExpandAllNodes}"
                                  Tag="ExpandAll"
                                  InputGesture="Ctrl+Alt+Right"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="ExpandAllTreeMenuItem"/>
                        <MenuItem Header="{DynamicResource CollapseAllNodes}"
                                  Tag="CollapseAll"
                                  InputGesture="Ctrl+Alt+Left"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="CollapseAllTreeMenuItem"/>
                        <Separator/>
                        <MenuItem Header="{DynamicResource CopyTaskOutline}"
                                  Tag="CopyOutline"
                                  InputGesture="Ctrl+Shift+C"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="CopyTaskOutlineTreeMenuItem"/>
                        <MenuItem Header="{DynamicResource PasteTaskOutline}"
                                  Tag="PasteOutline"
                                  InputGesture="Ctrl+Shift+V"
                                  Click="TaskTreeContextMenuItem_OnClick"
                                  AutomationProperties.AutomationId="PasteTaskOutlineTreeMenuItem"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="TreeView.TaskTree TreeViewItem">
            <Setter Property="IsExpanded">
                <Setter.Value>
                    <Binding Path="((viewModel:TaskWrapperViewModel)DataContext)?.IsExpanded"
                             Mode="TwoWay"
                             RelativeSource="{RelativeSource Mode=Self}"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Button.HotkeyHelpButton">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.HotkeyHelpButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource ThemeControlMidBrush}"/>
        </Style>
        <Style Selector="TextBlock.HotkeyPanelTitle">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="TextBlock.HotkeyPanelSectionTitle">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style Selector="Grid.HotkeyRow">
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style Selector="TextBlock.HotkeyRowLabel">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
        </Style>
        <Style Selector="Border.HotkeyChip">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeControlLowBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.HotkeyChipText">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas,Menlo,monospace"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>
    <UserControl.DataTemplates>
        <DataTemplate DataType="viewModel:TaskStatusOption">
            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource TaskStatusOptionDropDownTemplate}"/>
        </DataTemplate>
        <DataTemplate DataType="viewModel:WantedFilterOption">
            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
        </DataTemplate>
        <DataTemplate DataType="viewModel:TaskStatusFilter">
            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                <CheckBox IsChecked="{Binding ShowTasks}" VerticalAlignment="Center"/>
                <unlimotion:TaskStatusIcon Grid.Column="1"
                                           Status="{Binding Status}"
                                           Width="20"
                                           Height="20"
                                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding Title}" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="domain:TaskCompletionCriterion">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="4" Margin="0,0,0,2">
                <CheckBox IsChecked="{Binding IsSatisfied}"
                          VerticalAlignment="Center"
                          AutomationProperties.AutomationId="CompletionCriterionSatisfiedCheckBox"/>
                <TextBox Grid.Column="1"
                         Classes="CompletionCriterionTextBox BorderlessTextBoxChrome"
                         Text="{Binding Text}"
                         PlaceholderText="{DynamicResource CompletionCriterionWatermark}"
                         AutomationProperties.AutomationId="CompletionCriterionTextBox"/>
                <Button Grid.Column="2"
                        Classes="CompletionCriterionRemoveButton"
                        Click="CompletionCriterionRemoveButton_OnClick"
                        ToolTip.Tip="{DynamicResource Remove}"
                        AutomationProperties.AutomationId="CompletionCriterionRemoveButton">
                    <PathIcon Classes="RemoveButtonIcon" Data="M15.5,5.9 L14.1,4.5 L10,8.6 L5.9,4.5 L4.5,5.9 L8.6,10 L4.5,14.1 L5.9,15.5 L10,11.4 L14.1,15.5 L15.5,14.1 L11.4,10 Z"/>
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="domain:TaskStatusHistoryEntry">
            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8" Margin="0,0,0,4">
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding ChangedAt, StringFormat={}{0:yyyy.MM.dd HH:mm}}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding Author}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="viewModel:TaskItemViewModel">
            <Grid ColumnDefinitions="Auto, Auto, *" Background="Transparent" DragDrop.AllowDrop="True">
                <unlimotion:TaskStatusPicker Task="{Binding}"
                                             VerticalAlignment="Center"
                                             AutomationProperties.AutomationId="TaskStatusButton"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding RepeaterListMarker}"
                           IsVisible="{Binding IsHaveRepeater}"
                           ToolTip.Tip="{Binding RepeaterListMarkerToolTip}"
                           AutomationProperties.AutomationId="TaskRepeaterListMarker"
                           Margin="4,0,4,0"
                           VerticalAlignment="Center" />
                <unlimotion:EmojiTextBlock Grid.Column="2" EmojiText="{Binding Title}" VerticalAlignment="Center" HorizontalAlignment="Left" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" AutomationProperties.AutomationId="InlineTaskTitleTextBlock" Classes.IsWanted="{Binding Wanted}" Classes.IsCanBeCompleted="{Binding !IsCanBeCompleted}" PointerPressed="InlineTaskTitleText_OnPointerPressed"  />
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="viewModel:TaskWrapperViewModel">
            <Grid ColumnDefinitions="*,Auto" Background="Transparent">
                <ContentControl Content="{Binding TaskItem}" MinWidth="0"/>
                <Button Grid.Column="1"
                        Classes="TaskRowRemoveButton"
                        ToolTip.Tip="{DynamicResource Remove}"
                        Command="{Binding RemoveCommand}">
                    <PathIcon Classes="RemoveButtonIcon" Data="M15.5,5.9 L14.1,4.5 L10,8.6 L5.9,4.5 L4.5,5.9 L8.6,10 L4.5,14.1 L5.9,15.5 L10,11.4 L14.1,15.5 L15.5,14.1 L11.4,10 Z"/>
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="viewModel:TaskRelationCandidateViewModel">
            <StackPanel Margin="4,2">
                <TextBlock Text="{Binding Title}" />
                <TextBlock Text="{Binding Context}" Opacity="0.7" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="viewModel:EmojiFilter">
            <Grid ColumnDefinitions="Auto, Auto" >
                <CheckBox IsChecked="{Binding ShowTasks}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="viewModel:UnlockedTimeFilter">
            <CheckBox Content="{Binding Title}" IsChecked="{Binding ShowTasks}" VerticalAlignment="Center"/>
        </DataTemplate>
        <DataTemplate DataType="viewModel:DurationFilter">
            <CheckBox Content="{Binding Title}" IsChecked="{Binding ShowTasks}" VerticalAlignment="Center"/>
        </DataTemplate>
    </UserControl.DataTemplates>

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Shift+Delete" Command="{Binding DeleteSelectedTreeItemsCommand}"/>
        <KeyBinding Gesture="Ctrl+Enter" Command="{Binding CreateSibling}"/>
        <KeyBinding Gesture="Shift+Enter" Command="{Binding CreateBlockedSibling}"/>
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding CreateInner}"/>
        <KeyBinding Gesture="Ctrl+Shift+Right" Command="{Binding ExpandCurrentNestedCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+Left" Command="{Binding CollapseCurrentNestedCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+Right" Command="{Binding ExpandAllTreeNodesCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+Left" Command="{Binding CollapseAllTreeNodesCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding CopyTaskOutlineTreeCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+V" Command="{Binding PasteTaskOutlineTreeCommand}"/>
        <KeyBinding Gesture="Ctrl+D" Command="{Binding CompleteCurrentTaskCommand}"/>
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*">
        <!--Адрес-->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="10,5" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <unlimotion:EmojiTextBlock x:Name="BreadcrumbsTextBlock"
                                       AutomationProperties.AutomationId="BreadcrumbsTextBlock"
                                       EmojiText="{Binding BreadScrumbs}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"
                                       ToolTip.Tip="{Binding BreadScrumbs}"
                                       PointerPressed="BreadScrumbs_OnPointerPressed"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button Classes="HotkeyHelpButton"
                        Content="?"
                        ToolTip.Tip="{DynamicResource HotkeyPanelTitle}"
                        AutomationProperties.Name="{DynamicResource HotkeyPanelTitle}"
                        AutomationProperties.AutomationId="HotkeyHelpButton">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <Border Padding="16,12" MinWidth="300" MaxWidth="420"
                                    Background="{DynamicResource ThemeBackgroundBrush}">
                                <StackPanel Spacing="0">
                                    <TextBlock Text="{DynamicResource HotkeyPanelTitle}"
                                               Classes="HotkeyPanelTitle"/>
                                    <!-- Task Tree section -->
                                    <TextBlock Text="{DynamicResource HotkeySectionTaskTree}"
                                               Classes="HotkeyPanelSectionTitle"/>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyRenameTask}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RenameTask}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeySelectAll}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.SelectAll}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyDeleteSelection}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.DeleteSelection}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateSibling}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CreateSibling}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateBlockedSibling}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CreateBlockedSibling}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateInner}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CreateInner}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource ExpandCurrentNested}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.ExpandCurrent}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource CollapseCurrentNested}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CollapseCurrent}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource ExpandAllNodes}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.ExpandAll}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource CollapseAllNodes}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CollapseAll}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource CopyTaskOutline}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CopyOutline}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource PasteTaskOutline}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.PasteOutline}"/></Border>
                                    </Grid>
                                    <!-- Roadmap section -->
                                    <TextBlock Text="{DynamicResource HotkeySectionRoadmap}"
                                               Classes="HotkeyPanelSectionTitle"/>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyRenameTask}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapRenameTask}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateSibling}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapCreateSibling}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateBlockedSibling}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapCreateBlockedSibling}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateInner}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapCreateInner}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyRoadmapFitToScreen}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapFitToScreen}"/></Border>
                                    </Grid>
                                    <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyRoadmapResetViewport}"/>
                                        <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapResetViewport}"/></Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <DropDownButton Classes="TaskCreateMenuButton TaskAccentOutlineButton TaskIconOnlyDropDownButton"
                                Content="➕"
                                ToolTip.Tip="{DynamicResource CreateTaskMenuTip}"
                                AutomationProperties.Name="{DynamicResource CreateTaskMenuTip}"
                                AutomationProperties.AutomationId="GlobalTaskCreateMenuButton">
                    <DropDownButton.Flyout>
                        <MenuFlyout>
                            <MenuItem Classes="TaskCreateMenuItem"
                                      Header="{DynamicResource NewTask}"
                                      Command="{Binding Create}"
                                      AutomationProperties.AutomationId="GlobalTaskCreateTaskMenuItem"/>
                            <MenuItem Classes="TaskCreateMenuItem"
                                      Header="{DynamicResource NewSibling}"
                                      Command="{Binding CreateSibling}"
                                      AutomationProperties.AutomationId="GlobalTaskCreateSiblingMenuItem"/>
                            <MenuItem Classes="TaskCreateMenuItem"
                                      Header="{DynamicResource NewBlockedSibling}"
                                      Command="{Binding CreateBlockedSibling}"
                                      AutomationProperties.AutomationId="GlobalTaskCreateBlockedSiblingMenuItem"/>
                            <MenuItem Classes="TaskCreateMenuItem"
                                      Header="{DynamicResource NewInner}"
                                      Command="{Binding CreateInner}"
                                      AutomationProperties.AutomationId="GlobalTaskCreateInnerMenuItem"/>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
        </Grid>

        <!--Панель навигации-->
        <SplitView x:Name="MainNavigationSplitView"
                   Grid.Row="1"
                   IsPaneOpen="{Binding DetailsAreOpen}"
                   DisplayMode="CompactInline"
                   UseLightDismissOverlayMode="False"
                   OpenPaneLength="{Binding #mainControl.Bounds.Width, Converter={converters:MinValueConverter}, ConverterParameter=600}"
                   CompactPaneLength="20"
                   PanePlacement="Right">
            <Grid x:Name="MainTabsHost"
                  Margin="10,0,0,0"
                  HorizontalAlignment="Left">
                <TabControl x:Name="MainTabs"
                            TabStripPlacement="Top"
                            ClipToBounds="True"
                            Margin="0"
                            Padding="0"
                            SelectionChanged="MainTabs_OnSelectionChanged"
                            AutomationProperties.AutomationId="MainTabs">
                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="FontSize" Value="{DynamicResource AppTabFontSize}"/>
                            <Setter Property="Padding" Value="0,0,6,0"/>
                            <Setter Property="MinHeight" Value="{DynamicResource AppTabMinHeight}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                        <Style Selector="TabControl /template/ ContentPresenter#PART_SelectedContentHost">
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </TabControl.Styles>
                    <!--All Tasks-->
                    <TabItem Header="{DynamicResource AllTasks}" IsSelected= "{Binding AllTasksMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="AllTasksTabItem">
                        <Grid RowDefinitions= "Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
                                    <views:EmojiFilterMultiSelectSearchBox Filters="{Binding EmojiFilters}"
                                                                           Watermark="{DynamicResource EmojiFilterSearchWatermark}"
                                                                           NoMatchesText="{DynamicResource EmojiFilterNoMatches}"
                                                                           SummaryWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryWidth}"
                                                                           SummaryMinWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryMinWidth}"
                                                                           SummaryAutomationId="IncludeEmojiFilterSummaryBox"
                                                                           SearchAutomationId="IncludeEmojiFilterSearchBox"
                                                                           DropDownAutomationId="IncludeEmojiFilterDropDown"
                                                                           ListAutomationId="IncludeEmojiFilterList"
                                                                           NoMatchesAutomationId="IncludeEmojiFilterNoMatches"/>
                                    <views:EmojiFilterMultiSelectSearchBox Filters="{Binding EmojiExcludeFilters}"
                                                                           Watermark="{DynamicResource EmojiExcludeFilterSearchWatermark}"
                                                                           NoMatchesText="{DynamicResource EmojiFilterNoMatches}"
                                                                           IsExclude="True"
                                                                           SummaryWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryWidth}"
                                                                           SummaryMinWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryMinWidth}"
                                                                           SummaryAutomationId="ExcludeEmojiFilterSummaryBox"
                                                                           SearchAutomationId="ExcludeEmojiFilterSearchBox"
                                                                           DropDownAutomationId="ExcludeEmojiFilterDropDown"
                                                                           ListAutomationId="ExcludeEmojiFilterList"
                                                                           NoMatchesAutomationId="ExcludeEmojiFilterNoMatches"/>
                                    <DropDownButton Classes="FilterToolbarFiltersButton"
                                                    ToolTip.Tip="{DynamicResource Filters}"
                                                    AutomationProperties.Name="{DynamicResource Filters}"
                                                    Margin="0"
                                                    AutomationProperties.AutomationId="AllTasksFiltersButton">
                                        <PathIcon Classes="FilterToolbarFiltersIcon" Width="15" Height="15" Data="M3,5 L21,5 L21,7 L3,7 Z M7,11 L17,11 L17,13 L7,13 Z M10,17 L14,17 L14,19 L10,19 Z"/>
                                        <DropDownButton.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Classes="FilterOverflowPanel"
                                                        MinWidth="0"
                                                        MaxWidth="360"
                                                        AutomationProperties.AutomationId="AllTasksFilterPanel">
                                                    <ScrollViewer Classes="FilterPanelScrollViewer">
                                                        <StackPanel Spacing="10">
                                                            <StackPanel>
                                                                <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterSort}"/>
                                                                <ComboBox ItemsSource="{Binding SortDefinitions}" SelectedItem="{Binding CurrentSortDefinition}" MinWidth="220"/>
                                                            </StackPanel>
                                                            <StackPanel>
                                                                <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterState}"/>
                                                                <WrapPanel>
                                                                    <ComboBox ItemsSource="{Binding StatusFilters}" MinWidth="220" Margin="0,0,8,6" AutomationProperties.AutomationId="AllTasksStatusFilterComboBox"/>
                                                                </WrapPanel>
                                                            </StackPanel>
                                                            <Button Classes="FilterPanelResetButton"
                                                                    ToolTip.Tip="{DynamicResource ResetFilters}"
                                                                    AutomationProperties.Name="{DynamicResource ResetFilters}"
                                                                    Command="{Binding ResetTaskFiltersCommand}"
                                                                    AutomationProperties.AutomationId="AllTasksResetFiltersButton">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <PathIcon Classes="FilterPanelResetIcon" Width="16" Height="16" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.82,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                                                                    <TextBlock Text="{DynamicResource ResetFilters}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Flyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                </WrapPanel>
                                <searchControl:SearchBar Grid.Column="1" Classes="FilterToolbarSearch" DataContext="{Binding Search}"/>
                            </Grid>
                            <TreeView Grid.Row= "1" AutoScrollToSelectedItem= "True"
                                      ItemsSource="{Binding CurrentAllTasksItems}"
                                      SelectedItem="{Binding CurrentAllTasksItem}"
                                      SelectionMode= "Multiple"
                                      Classes="TaskTree"
                                      PointerPressed="TaskTree_OnPointerPressed"
                                      KeyDown="TaskTree_OnKeyDown"
                                      AutomationProperties.AutomationId="AllTasksTree"
                                      x:Name="AllTasksTree">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType= "viewModel:TaskWrapperViewModel" ItemsSource= "{Binding SubTasks}">
                                        <ContentControl Content= "{Binding .}" PointerPressed= "InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased" DoubleTapped= "TaskTree_OnDoubleTapped"/>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Last Created-->
                    <TabItem Header="{DynamicResource LastCreated}" IsSelected="{Binding LastCreatedMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="LastCreatedTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
                                    <views:EmojiFilterMultiSelectSearchBox Filters="{Binding EmojiFilters}"
                                                                           Watermark="{DynamicResource EmojiFilterSearchWatermark}"
                                                                           NoMatchesText="{DynamicResource EmojiFilterNoMatches}"
                                                                           SummaryWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryWidth}"
                                                                           SummaryMinWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryMinWidth}"
                                                                           SummaryAutomationId="IncludeEmojiFilterSummaryBox"
                                                                           SearchAutomationId="IncludeEmojiFilterSearchBox"
                                                                           DropDownAutomationId="IncludeEmojiFilterDropDown"
                                                                           ListAutomationId="IncludeEmojiFilterList"
                                                                           NoMatchesAutomationId="IncludeEmojiFilterNoMatches"/>
                                    <views:EmojiFilterMultiSelectSearchBox Filters="{Binding EmojiExcludeFilters}"
                                                                           Watermark="{DynamicResource EmojiExcludeFilterSearchWatermark}"
                                                                           NoMatchesText="{DynamicResource EmojiFilterNoMatches}"
                                                                           IsExclude="True"
                                                                           SummaryWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryWidth}"
                                                                           SummaryMinWidth="{x:Static views:EmojiFilterMultiSelectSearchBox.DefaultSummaryMinWidth}"
                                                                           SummaryAutomationId="ExcludeEmojiFilterSummaryBox"
                                                                           SearchAutomationId="ExcludeEmojiFilterSearchBox"
                                                                           DropDownAutomationId="ExcludeEmojiFilterDropDown"
                                                                           ListAutomationId="ExcludeEmojiFilterList"
                                                                           NoMatchesAutomationId="ExcludeEmojiFilterNoMatches"/>
                                    <DropDownButton Classes="FilterToolbarFiltersButton"
                                                    ToolTip.Tip="{DynamicResource Filters}"
                                                    AutomationProperties.Name="{DynamicResource Filters}"
                                                    Margin="0"
                                                    AutomationProperties.AutomationId="LastCreatedFiltersButton">
                                        <PathIcon Classes="FilterToolbarFiltersIcon" Width="15" Height="15" Data="M3,5 L21,5 L21,7 L3,7 Z M7,11 L17,11 L17,13 L7,13 Z M10,17 L14,17 L14,19 L10,19 Z"/>
                                        <DropDownButton.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Classes="FilterOverflowPanel"
                                                        MinWidth="0"
                                                        MaxWidth="360"
                                                        AutomationProperties.AutomationId="LastCreatedFilterPanel">
                                                    <ScrollViewer Classes="FilterPanelScrollViewer">
                                                    <StackPanel Spacing="10">
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterDate}"/>
                                                            <WrapPanel>
                                                                <CheckBox Content="{DynamicResource CustomPeriod}" IsChecked="{Binding LastCreatedDateFilter.IsCustom}" Margin="0,0,12,6" VerticalAlignment="Center"/>
                                                                <ComboBox IsVisible="{Binding !LastCreatedDateFilter.IsCustom}" ItemsSource="{Binding DateFilterDefinitions}" SelectedItem="{Binding LastCreatedDateFilter.CurrentOption}" VerticalAlignment="Center" Margin="0,0,8,6" />
                                                            </WrapPanel>
                                                            <WrapPanel IsVisible="{Binding LastCreatedDateFilter.IsCustom}">
                                                                <Label Content="{DynamicResource From}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding LastCreatedDateFilter.From}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding LastCreatedDateFilter.From, Converter={converters:DayOrTodayValueConverter}}"/>
                                                                <Label Content="{DynamicResource To}" Margin="0,0,6,6" VerticalAlignment="Center"/>
                                                                <CalendarDatePicker Margin="0,0,8,6"
                                                                                    SelectedDate="{Binding LastCreatedDateFilter.To}"
                                                                                    IsTodayHighlighted="True"
                                                                                    DisplayDate="{Binding LastCreatedDateFilter.To, Converter={converters:DayOrTodayValueConverter}}"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Classes="FilterPanelGroupTitle" Text="{DynamicResource FilterState}"/>
                                                            <WrapPanel>
                                                                <ComboBox ItemsSource="{Binding LastCreatedStatusFilters}" MinWidth="220" Margin="0,0,8,6" AutomationProperties.AutomationId="LastCreatedStatusFilterComboBox"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <Button Classes="FilterPanelResetButton"
                                                                ToolTip.Tip="{DynamicResource ResetFilters}"
                                                                AutomationProperties.Name="{DynamicResource ResetFilters}"
                                                                Command="{Binding ResetTaskFiltersCommand}"
                                                                AutomationProperties.AutomationId="LastCreatedResetFiltersButton">
                                                            <StackPanel Orientation="Horizontal">
                                                                <PathIcon Classes="FilterPanelResetIcon" Width="16" Height="16" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.82,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                                                                <TextBlock Text="{DynamicResource ResetFilters}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Flyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                </WrapPanel>
                                <searchControl:SearchBar Grid.Column="1" Classes="FilterToolbarSearch" DataContext="{Binding Search}"/>
                            </Grid>
                            <TreeView Grid.Row="1" AutoScrollToSelectedItem="True"
                                      ItemsSource="{Binding LastCreatedItems}"
                                      SelectedItem="{Binding CurrentLastCreated}"
                                      SelectionMode="Multiple"
                                      Classes="TaskTree"
                                      PointerPressed="TaskTree_OnPointerPressed"
                                      KeyDown="TaskTree_OnKeyDown"
                                      AutomationProperties.AutomationId="LastCreatedTree"
                                      x:Name="LastCreatedTree">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="viewModel:TaskWrapperViewModel" ItemsSource="{Binding SubTasks}">
                                        <Grid DoubleTapped="TaskTree_OnDoubleTapped" Background="Transparent">
                                            <Grid ColumnDefinitions="Auto, Auto, Auto, Auto,*" DragDrop.AllowDrop="True" PointerPressed="InputElement_OnPointerPressed" PointerMoved="InputElement_OnPointerMoved" PointerReleased="InputElement_OnPointerReleased">
                                                <unlimotion:TaskStatusPicker Task="{Binding TaskItem}" VerticalAlignment="Center" AutomationProperties.AutomationId="TaskStatusButton" />
                                                <Label Grid.Column="1" Classes="TaskTreeMetaLabel" Content="{Binding TaskItem.CreatedDateTime, StringFormat={}{0:yyyy.MM.dd}}" Foreground="{StaticResource AccentButtonBackground}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <Label Grid.Column="2" Content="{Binding TaskItem.GetAllEmoji}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TaskItem.RepeaterListMarker}"
                                                           IsVisible="{Binding TaskItem.IsHaveRepeater}"
                                                           ToolTip.Tip="{Binding TaskItem.RepeaterListMarkerToolTip}"
                                                           AutomationProperties.AutomationId="TaskRepeaterListMarker"
                                                           Margin="4,0,4,0"
                                                           VerticalAlignment="Center" />
                                                <Grid Grid.Column="4" VerticalAlignment="Center">
                                                    <unlimotion:EmojiTextBlock EmojiText="{Binding TaskItem.Title}" VerticalAlignment="Center" HorizontalAlignment="Left" AutomationProperties.AutomationId="InlineTaskTitleTextBlock" Classes.IsWanted="{Binding TaskItem.Wanted}" PointerPressed="InlineTaskTitleText_OnPointerPressed"/>
                                                </Grid>
                                            </Grid>
                                            <Button Classes="TaskRowRemoveButton"
                                                    ToolTip.Tip="{DynamicResource Remove}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding RemoveCommand}">
                                                <PathIcon Classes="RemoveButtonIcon" Data="M15.5,5.9 L14.1,4.5 L10,8.6 L5.9,4.5 L4.5,5.9 L8.6,10 L4.5,14.1 L5.9,15.5 L10,11.4 L14.1,15.5 L15.5,14.1 L11.4,10 Z"/>
                                            </Button>
                                        </Grid>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    <!--Last Updated-->
                    <TabItem Header="{DynamicResource LastUpdated}" IsSelected="{Binding LastUpdatedMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="LastUpdatedTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
                                <WrapPanel Grid.Column="0" Classes="FilterToolbarItems">
