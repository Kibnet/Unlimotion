                    </TabItem>
                    <!--In Progress-->
                    <TabItem Header="{DynamicResource InProgress}" IsSelected="{Binding InProgressMode, Mode=OneWayToSource}"
                             AutomationProperties.AutomationId="InProgressTabItem">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Classes="FilterToolbar" ColumnDefinitions="Auto,*">
