<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:unlimotion="clr-namespace:Unlimotion"
             mc:Ignorable="d"
             d:DesignWidth="520"
             d:DesignHeight="300"
             x:Class="Unlimotion.Views.HotkeyHelpPanel">
    <UserControl.Styles>
        <Style Selector="TextBlock.HotkeyPanelTitle">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="TextBlock.HotkeyPanelSectionTitle">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style Selector="Grid.HotkeyRow">
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="Width" Value="488"/>
        </Style>
        <Style Selector="TextBlock.HotkeyRowLabel">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>
        <Style Selector="Border.HotkeyChip">
            <Setter Property="Grid.Column" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeControlLowBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.HotkeyChipText">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas,Menlo,monospace"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Border Width="520"
            Padding="16,12"
            MaxHeight="300"
            Background="{DynamicResource ThemeBackgroundBrush}"
            AutomationProperties.AutomationId="HotkeyPanel">
        <ScrollViewer MaxHeight="276"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      AutomationProperties.AutomationId="HotkeyPanelScrollViewer">
            <StackPanel Width="488" Spacing="0">
                <TextBlock Text="{DynamicResource HotkeyPanelTitle}"
                           Classes="HotkeyPanelTitle"
                           AutomationProperties.AutomationId="HotkeyPanelTitleText"/>

                <TextBlock Text="{DynamicResource HotkeySectionGeneral}"
                           Classes="HotkeyPanelSectionTitle"
                           AutomationProperties.AutomationId="HotkeyGeneralSectionTitle"/>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyGeneralOpenHotkeyHelpRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyOpenHotkeyHelp}"/>
                    <Border Classes="HotkeyChip" AutomationProperties.AutomationId="HotkeyGeneralOpenHotkeyHelpChip">
                        <TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.OpenHotkeyHelp}"/>
                    </Border>
                </Grid>

                <TextBlock Text="{DynamicResource HotkeySectionTaskTree}"
                           Classes="HotkeyPanelSectionTitle"
                           AutomationProperties.AutomationId="HotkeyTaskTreeSectionTitle"/>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeRenameTaskRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyRenameTask}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RenameTask}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeSelectAllRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeySelectAll}"/>
                    <Border Classes="HotkeyChip" AutomationProperties.AutomationId="HotkeyTaskTreeSelectAllChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.SelectAll}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeDeleteSelectionRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyDeleteSelection}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.DeleteSelection}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeCompleteCurrentTaskRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCompleteCurrentTask}"/>
                    <Border Classes="HotkeyChip" AutomationProperties.AutomationId="HotkeyTaskTreeCompleteCurrentTaskChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CompleteCurrentTask}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeCreateSiblingRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateSibling}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CreateSibling}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeCreateBlockedSiblingRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateBlockedSibling}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CreateBlockedSibling}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeCreateInnerRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateInner}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CreateInner}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeExpandCurrentRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource ExpandCurrentNested}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.ExpandCurrent}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeCollapseCurrentRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource CollapseCurrentNested}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CollapseCurrent}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeExpandAllRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource ExpandAllNodes}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.ExpandAll}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeCollapseAllRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource CollapseAllNodes}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CollapseAll}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreeCopyOutlineRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource CopyTaskOutline}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.CopyOutline}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyTaskTreePasteOutlineRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource PasteTaskOutline}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.PasteOutline}"/></Border>
                </Grid>

                <TextBlock Text="{DynamicResource HotkeySectionRoadmap}"
                           Classes="HotkeyPanelSectionTitle"
                           AutomationProperties.AutomationId="HotkeyRoadmapSectionTitle"/>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyRoadmapRenameTaskRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyRenameTask}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapRenameTask}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyRoadmapCreateSiblingRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateSibling}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapCreateSibling}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyRoadmapCreateBlockedSiblingRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateBlockedSibling}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapCreateBlockedSibling}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyRoadmapCreateInnerRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyCreateInner}"/>
                    <Border Classes="HotkeyChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapCreateInner}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyRoadmapFitToScreenRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyRoadmapFitToScreen}"/>
                    <Border Classes="HotkeyChip" AutomationProperties.AutomationId="HotkeyRoadmapFitToScreenChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapFitToScreen}"/></Border>
                </Grid>
                <Grid Classes="HotkeyRow" ColumnDefinitions="*,Auto"
                      AutomationProperties.AutomationId="HotkeyRoadmapResetViewportRow">
                    <TextBlock Classes="HotkeyRowLabel" Text="{DynamicResource HotkeyRoadmapResetViewport}"/>
                    <Border Classes="HotkeyChip" AutomationProperties.AutomationId="HotkeyRoadmapResetViewportChip"><TextBlock Classes="HotkeyChipText" Text="{x:Static unlimotion:HotkeyHints.RoadmapResetViewport}"/></Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
