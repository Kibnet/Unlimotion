<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModel="clr-namespace:Unlimotion.ViewModel;assembly=Unlimotion.ViewModel"
             mc:Ignorable="d"
             d:DesignWidth="220"
             d:DesignHeight="36"
             x:Class="Unlimotion.Views.EmojiFilterMultiSelectSearchBox"
             x:Name="Root"
             x:CompileBindings="False">
    <UserControl.Styles>
        <Style Selector="TextBox.EmojiFilterSummaryInput">
            <Setter Property="MinWidth" Value="{Binding SummaryMinWidth, ElementName=Root}"/>
            <Setter Property="MaxWidth" Value="{Binding SummaryWidth, ElementName=Root}"/>
            <Setter Property="Height" Value="{DynamicResource AppSearchControlHeight}"/>
            <Setter Property="MinHeight" Value="{DynamicResource AppSearchControlHeight}"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.EmojiFilterSummaryInput.Exclude">
            <Setter Property="Background" Value="#11CF222E"/>
            <Setter Property="BorderBrush" Value="#CF222E"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBox.EmojiFilterSummaryInput.EmptySummary">
            <Setter Property="Foreground" Value="#99FFFFFF"/>
        </Style>
        <Style Selector="TextBlock.EmojiFilterExcludeMarker">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="-8,0,0,0"/>
            <Setter Property="Foreground" Value="#CF222E"/>
            <Setter Property="FontSize" Value="{DynamicResource AppSmallFontSize}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Border.EmojiFilterDropDown">
            <Setter Property="Background" Value="{DynamicResource ThemeBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlMidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="MaxHeight" Value="260"/>
        </Style>
        <Style Selector="Border.EmojiFilterNoMatchesPanel">
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Background" Value="#FF3B3B3B"/>
            <Setter Property="BorderBrush" Value="#FF5C5C5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="TextBlock.EmojiFilterNoMatches">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
            <Setter Property="Foreground" Value="#F59E0B"/>
        </Style>
        <Style Selector="ListBox.EmojiFilterList">
            <Setter Property="MaxHeight" Value="220"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        <Style Selector="ListBox.EmojiFilterList ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="2,2"/>
        </Style>
        <Style Selector="CheckBox.EmojiFilterItemCheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TextBlock.EmojiFilterItemEmoji">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
            <Setter Property="Margin" Value="4,0,6,0"/>
            <Setter Property="MinWidth" Value="20"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.EmojiFilterItemTitle">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </UserControl.Styles>

    <Grid Margin="0,0,4,0" ClipToBounds="False">
        <TextBox x:Name="PART_Input"
                 Classes="EmojiFilterSummaryInput"
                 IsReadOnly="True"
                 TextChanged="Input_OnTextChanged"/>
        <TextBlock x:Name="PART_ExcludeMarker"
                   Classes="EmojiFilterExcludeMarker"
                   Text="-"/>
        <Popup x:Name="PART_DropDownPopup"
               PlacementTarget="{Binding #PART_Input}"
               Placement="BottomEdgeAlignedLeft"
               IsLightDismissEnabled="True"
               OverlayDismissEventPassThrough="True"
               OverlayInputPassThroughElement="{Binding #PART_Input}"
               Closed="DropDownPopup_OnClosed">
            <Border x:Name="PART_DropDown"
                    Classes="EmojiFilterDropDown">
                <StackPanel>
                    <Border x:Name="PART_NoMatchesPanel"
                            Classes="EmojiFilterNoMatchesPanel"
                            IsVisible="False">
                        <TextBlock x:Name="PART_NoMatches"
                                   Classes="EmojiFilterNoMatches"/>
                    </Border>
                    <ListBox x:Name="PART_List"
                             Classes="EmojiFilterList"
                             Focusable="True"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="viewModel:EmojiFilter">
                                <Grid ColumnDefinitions="Auto,Auto,*"
                                      MinWidth="0"
                                      VerticalAlignment="Center">
                                    <CheckBox Classes="EmojiFilterItemCheckBox"
                                              IsChecked="{Binding ShowTasks, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1"
                                               Classes="EmojiFilterItemEmoji"
                                               Text="{Binding Emoji}"/>
                                    <TextBlock Grid.Column="2"
                                               Classes="EmojiFilterItemTitle"
                                               Text="{Binding DisplayTitle}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
