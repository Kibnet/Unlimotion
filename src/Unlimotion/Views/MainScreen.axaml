<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModel="clr-namespace:Unlimotion.ViewModel;assembly=Unlimotion.ViewModel"
             xmlns:views="clr-namespace:Unlimotion.Views"
             xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
             xmlns:unlimotion="clr-namespace:Unlimotion"
             xmlns:controls="clr-namespace:Avalonia.Notification.Controls;assembly=Notification.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Unlimotion.Views.MainScreen"
             FontSize="{DynamicResource AppFontSize}"
             x:DataType="viewModel:MainWindowViewModel">

    <Design.DataContext>
        <viewModel:MainWindowViewModel/>
    </Design.DataContext>
    <Panel>
        <dialogHostAvalonia:DialogHost CloseOnClickAway="True" Identifier="Ask">
            <dialogHostAvalonia:DialogHost.DataTemplates>
                <DataTemplate DataType="unlimotion:AskViewModel">

                    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto">

                        <TextBlock TextAlignment="Center"
								   TextWrapping="Wrap"
								   FontWeight="Bold"
								   Text="{Binding Header}"/>
                        <TextBlock Grid.Row="1" TextAlignment="Center"
								   TextWrapping="Wrap"
								   Text="{Binding Message}" />
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
									HorizontalAlignment="Stretch"
									HorizontalContentAlignment="Center"
									Command="{Binding YesCommand}"
									Content="{DynamicResource DialogYes}"/>
                            <Button Grid.Column="1"
									HorizontalAlignment="Stretch"
									HorizontalContentAlignment="Center"
									Command="{Binding NoCommand}"
									Content="{DynamicResource DialogNo}"/>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </dialogHostAvalonia:DialogHost.DataTemplates>
            <!-- put the content over which the dialog is shown here (e.g. your main window grid)-->
            <Panel>
                <views:MainControl Name="MainControl"/>
                <controls:NotificationMessageContainer
                    Manager="{Binding ToastNotificationManager}"
                    HorizontalAlignment="Center"/>
                <Grid x:Name="TasksLoadingOverlay"
                      IsVisible="{Binding IsTasksLoading}"
                      AutomationProperties.AutomationId="TasksLoadingOverlay">
                    <Border Background="#66000000"/>
                    <Border MaxWidth="260"
                            Padding="20"
                            CornerRadius="14"
                            Background="#F2FFFFFF"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Spacing="12">
                            <Grid x:Name="TasksLoadingSpinner"
                                  Width="34"
                                  Height="34"
                                  HorizontalAlignment="Center"
                                  RenderTransformOrigin="50%,50%"
                                  AutomationProperties.AutomationId="TasksLoadingSpinner">
                                <Border Width="6"
                                        Height="14"
                                        CornerRadius="3"
                                        Background="Black"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"/>
                                <Ellipse Width="6"
                                         Height="6"
                                         Fill="#40000000"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Bottom"/>
                            </Grid>
                            <TextBlock Text="{DynamicResource LoadingTasks}"
                                       Foreground="Black"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </Panel>
        </dialogHostAvalonia:DialogHost>
    </Panel>
</UserControl>
