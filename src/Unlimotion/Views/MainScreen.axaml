<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModel="clr-namespace:Unlimotion.ViewModel;assembly=Unlimotion.ViewModel"
             xmlns:views="clr-namespace:Unlimotion.Views"
             xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
             xmlns:unlimotion="clr-namespace:Unlimotion"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Unlimotion.Views.MainScreen"
             FontSize="{DynamicResource AppFontSize}"
             x:DataType="viewModel:MainWindowViewModel">

    <Design.DataContext>
        <viewModel:MainWindowViewModel/>
    </Design.DataContext>
    <Panel>
        <dialogHostAvalonia:DialogHost CloseOnClickAway="True" Identifier="Ask">
            <dialogHostAvalonia:DialogHost.DataTemplates>
                <DataTemplate DataType="unlimotion:AskViewModel">

                    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto">

                        <TextBlock TextAlignment="Center"
								   TextWrapping="Wrap"
								   FontWeight="Bold"
								   Text="{Binding Header}"/>
                        <TextBlock Grid.Row="1" TextAlignment="Center"
								   TextWrapping="Wrap"
								   Text="{Binding Message}" />
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
									HorizontalAlignment="Stretch"
									HorizontalContentAlignment="Center"
									Command="{Binding YesCommand}"
									Content="{DynamicResource DialogYes}"/>
                            <Button Grid.Column="1"
									HorizontalAlignment="Stretch"
									HorizontalContentAlignment="Center"
									Command="{Binding NoCommand}"
									Content="{DynamicResource DialogNo}"/>
                        </Grid>
                    </Grid>
                </DataTemplate>
                <DataTemplate DataType="unlimotion:TaskOutlinePastePreviewDialogViewModel">
                    <views:TaskOutlinePastePreviewControl />
                </DataTemplate>
                <DataTemplate DataType="viewModel:SettingsViewModel">
                    <views:ConflictResolutionControl />
                </DataTemplate>
            </dialogHostAvalonia:DialogHost.DataTemplates>
            <!-- put the content over which the dialog is shown here (e.g. your main window grid)-->
            <Panel>
                <views:MainControl Name="MainControl"/>
                <ItemsControl x:CompileBindings="False"
                              ItemsSource="{Binding ToastNotificationManager.Messages}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Top"
                              Margin="16"
                              AutomationProperties.AutomationId="ToastNotificationList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="unlimotion:AppToastNotification"
                                      x:DataType="unlimotion:AppToastNotification">
                            <Border MinWidth="280"
                                    MaxWidth="560"
                                    Padding="12,10"
                                    CornerRadius="6"
                                    Background="{Binding Background}"
                                    AutomationProperties.AutomationId="{Binding AutomationId}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{Binding Message}"
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            MinWidth="28"
                                            MinHeight="28"
                                            Margin="12,0,0,0"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="White"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Content="x"
                                            Command="{Binding CloseCommand}"
                                            AutomationProperties.AutomationId="{Binding CloseAutomationId}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Grid x:Name="TasksLoadingOverlay"
                      IsVisible="{Binding IsTasksLoading}"
                      AutomationProperties.AutomationId="TasksLoadingOverlay">
                    <Border Background="#66000000"/>
                    <Border MaxWidth="260"
                            Padding="20"
                            CornerRadius="14"
                            Background="#F2FFFFFF"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Spacing="12">
                            <Grid x:Name="TasksLoadingSpinner"
                                  Width="34"
                                  Height="34"
                                  HorizontalAlignment="Center"
                                  RenderTransformOrigin="50%,50%"
                                  AutomationProperties.AutomationId="TasksLoadingSpinner">
                                <Border Width="6"
                                        Height="14"
                                        CornerRadius="3"
                                        Background="Black"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"/>
                                <Ellipse Width="6"
                                         Height="6"
                                         Fill="#40000000"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Bottom"/>
                            </Grid>
                            <TextBlock Text="{DynamicResource LoadingTasks}"
                                       Foreground="Black"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </Panel>
        </dialogHostAvalonia:DialogHost>
    </Panel>
</UserControl>
