<!--
  Unlimotion · "Aurora" — ICON GEOMETRIES
  =======================================
  Filled glyph geometries (24-grid) used via PathIcon, so they inherit
  Foreground from their parent (follow nav selection/hover color).
  A line-style Lucide set can replace these later; keep the keys stable.
  Included via ResourceInclude in App.Resources.
-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- All tasks — list -->
  <StreamGeometry x:Key="IconList">M3 5h18v2.6H3z M3 10.7h18v2.6H3z M3 16.4h18v2.6H3z</StreamGeometry>
  <!-- Last created — plus -->
  <StreamGeometry x:Key="IconPlus">M10.7 3h2.6v7.7H21v2.6h-7.7V21h-2.6v-7.7H3v-2.6h7.7z</StreamGeometry>
